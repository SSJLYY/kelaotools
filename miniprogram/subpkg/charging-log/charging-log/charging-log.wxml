<!-- 充电记录列表 -->
<view class="page {{darkMode ? 'dark-mode' : ''}}">

  <!-- 导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack">
        <text class="nav-back-icon">‹</text>
      </view>
      <view class="nav-title-text">充电记录</view>
      <view class="nav-right-btn" bindtap="onMonthReport">
        <text class="nav-report-text">月报</text>
      </view>
    </view>
  </view>
  <view style="height: {{navTotalHeight}}px;"></view>

  <!-- 摘要统计 -->
  <view class="summary-bar" wx:if="{{records.length > 0}}">
    <text class="summary-text">共{{records.length}}条记录</text>
    <text class="summary-amount">¥{{totalAmount}}</text>
  </view>

  <!-- 记录列表 -->
  <block wx:if="{{records.length > 0}}">
    <view class="record-list">
      <view wx:for="{{records}}" wx:key="id" class="record-card" bindtap="onRecordTap" data-id="{{item.id}}">
        <view class="record-left">
          <view class="record-icon-box" style="background: {{item.typeBg}};">
            <text class="record-icon">{{item.typeIcon}}</text>
          </view>
          <view class="record-info">
            <view class="record-top">
              <text class="record-type">{{item.typeName}}</text>
              <text class="record-price">¥{{item.price}}</text>
            </view>
            <text class="record-detail">{{item.kwh}}kWh · {{item.station}}</text>
            <text class="record-date">{{item.date}}</text>
          </view>
        </view>
        <text class="record-arrow">›</text>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{records.length === 0 && !loading}}">
    <view class="empty-box">
      <text class="empty-emoji">⚡</text>
      <text class="empty-title">暂无充电记录</text>
      <text class="empty-desc">记录每一次充电，随时掌握费用动态</text>
    </view>
    <button class="empty-btn" bindtap="onAdd">＋ 记一笔充电</button>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab-btn" wx:if="{{records.length > 0}}" bindtap="onAdd">
    <text class="fab-icon">＋</text>
  </view>

  <!-- safe bottom -->
  <view style="height:100rpx;" wx:if="{{records.length > 0}}"></view>
</view>
