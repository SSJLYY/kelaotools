/* 添加充电记录 */
.nav-bar { position:fixed; top:0; left:0; right:0; z-index:100; background:rgba(255,255,255,0.97); border-bottom:1rpx solid rgba(0,0,0,0.05); }
.nav-content { display:flex; align-items:center; padding:0 24rpx; }
.nav-back { width:80rpx; } .nav-right-placeholder{width:80rpx;}
.nav-back-icon { font-size:48rpx; font-weight:300; color:var(--text-primary); }
.nav-title-text { flex:1; text-align:center; font-size:34rpx; font-weight:600; }

.form-section { margin:16rpx 24rpx; background:#FFF; border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-sm); }
.form-item { padding:24rpx; border-bottom:1rpx solid var(--border-light); }
.form-item:last-child { border-bottom:none; }
.form-label { font-size:var(--font-sm); font-weight:600; color:var(--text-primary); display:block; margin-bottom:12rpx; }
.form-label-sub { font-size:20rpx; color:var(--text-light); display:block; margin-top:4rpx; }
.input-wrapper { display:flex; align-items:center; background:#F5F5F7; border-radius:var(--radius-sm); padding:0 20rpx; height:76rpx; }
.input-value { flex:1; font-size:var(--font-md); color:var(--text-primary); }
.placeholder { color:var(--text-placeholder); }
.form-input { flex:1; font-size:var(--font-md); color:var(--text-primary); height:76rpx; }
.input-suffix { font-size:var(--font-sm); color:var(--text-light); margin-left:8rpx; }
.input-arrow { font-size:32rpx; color:#CCC; }
.form-textarea { width:100%; min-height:120rpx; font-size:var(--font-sm); background:#F5F5F7; border-radius:var(--radius-sm); padding:16rpx 20rpx; box-sizing:border-box; }
.switch-row { display:flex; align-items:center; justify-content:space-between; }

/* type selector */
.type-selector { display:flex; gap:16rpx; }
.type-option { flex:1; text-align:center; padding:20rpx 0; background:#F5F5F7; border-radius:var(--radius-md); border:3rpx solid transparent; transition:all .2s; }
.type-active { border-color:var(--primary); background:var(--primary-light); }
.type-icon { font-size:40rpx; display:block; }
.type-name { font-size:var(--font-xs); color:var(--text-secondary); display:block; margin-top:6rpx; }
.type-active .type-name { color:var(--primary); font-weight:600; }

.bottom-btn-area { padding:24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom)); }
.save-btn { width:100%; height:92rpx; background:linear-gradient(135deg,#0066FF,#5B3FFF); border-radius:46rpx; border:none; font-size:var(--font-md); font-weight:700; color:#FFF; display:flex; align-items:center; justify-content:center; }

/* ===== 深色模式 ===== */
.dark-mode .nav-bar {
  background: rgba(26, 26, 26, 0.97) !important;
  border-bottom-color: rgba(255, 255, 255, 0.05) !important;
}

.dark-mode .nav-back-icon {
  color: #E5E5E5 !important;
}

.dark-mode .nav-title-text {
  color: #E5E5E5 !important;
}

.dark-mode .nav-right-placeholder {
  color: #E5E5E5 !important;
}

.dark-mode .form-section {
  background: #1E1E1E !important;
}

.dark-mode .form-item {
  border-bottom-color: #333333 !important;
}

.dark-mode .form-label {
  color: #E5E5E5 !important;
}

.dark-mode .form-label-sub {
  color: #A0A0A0 !important;
}

.dark-mode .input-wrapper {
  background: #2A2A2A !important;
}

.dark-mode .input-value,
.dark-mode .form-input {
  color: #E5E5E5 !important;
}

.dark-mode .input-suffix {
  color: #A0A0A0 !important;
}

.dark-mode .input-arrow {
  color: #666666 !important;
}

.dark-mode .form-textarea {
  background: #2A2A2A !important;
  color: #E5E5E5 !important;
}

.dark-mode .type-option {
  background: #2A2A2A !important;
}

.dark-mode .type-name {
  color: #A0A0A0 !important;
}

.dark-mode .type-active {
  background: #1a2a3a !important;
  border-color: #0066FF !important;
}

.dark-mode .type-active .type-name {
  color: #4D94FF !important;
}

