.page {
  min-height: 100vh;
  background: #F5F7FA;
  color: #111827;
  box-sizing: border-box;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(245, 247, 250, 0.96);
  backdrop-filter: blur(20rpx);
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back,
.nav-spacer {
  width: 96rpx;
}

.nav-back {
  font-size: 58rpx;
  line-height: 1;
  color: #111827;
  font-weight: 300;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}

.category-scroll {
  white-space: nowrap;
  padding: 24rpx 0 12rpx;
}

.category-list {
  display: inline-flex;
  padding: 0 16rpx;
  gap: 14rpx;
  flex-wrap: nowrap;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 28rpx;
  border-radius: 36rpx;
  background: #FFF;
  color: #64748B;
  border: 2rpx solid #E2E8F0;
  font-size: 26rpx;
  font-weight: 700;
}

.chip-active {
  background: #2F66F6;
  color: #FFF;
  border-color: #2F66F6;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 16rpx 18rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #111827;
}

.section-sub {
  display: block;
  font-size: 24rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stats-btn,
.add-btn {
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  border: none;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-btn {
  background: #EFF4F9;
  color: #475569;
}

.add-btn {
  background: #2F66F6;
  color: #FFF;
}

.record-list {
  padding: 0 16rpx 120rpx;
}

.record-card {
  display: flex;
  align-items: center;
  min-height: 118rpx;
  padding: 22rpx 28rpx;
  margin-bottom: 18rpx;
  background: #FFF;
  border: 2rpx solid #DFE7F0;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.record-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 14rpx;
  background: #EEF4FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}

.record-main {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.record-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #111827;
}

.record-note {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748B;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.record-right {
  min-width: 150rpx;
  text-align: right;
}

.record-amount {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #2563EB;
}

.delete-link {
  display: block;
  font-size: 22rpx;
  color: #EF4444;
  margin-top: 4rpx;
}

.record-date {
  display: block;
  font-size: 22rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.empty-state {
  margin: 80rpx 32rpx 0;
  padding: 56rpx 28rpx;
  background: #FFF;
  border-radius: 24rpx;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 84rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  margin-top: 12rpx;
}

.empty-sub {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.empty-add {
  width: 260rpx;
  height: 76rpx;
  margin-top: 28rpx;
  border-radius: 38rpx;
  background: #2F66F6;
  color: #FFF;
  font-size: 26rpx;
  font-weight: 800;
  border: none;
}

.float-add {
  position: fixed;
  right: 42rpx;
  bottom: calc(84rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #2F66F6;
  color: #FFF;
  font-size: 46rpx;
  font-weight: 300;
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(47, 102, 246, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.form-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 44rpx 32rpx 28rpx;
}

.form-title {
  font-size: 34rpx;
  font-weight: 900;
}

.close-btn {
  font-size: 42rpx;
  color: #94A3B8;
  padding: 4rpx 10rpx;
}

.form-card {
  margin: 0 28rpx;
  padding: 28rpx 28rpx 16rpx;
  background: #FFF;
  border: 2rpx solid #E2E8F0;
  border-radius: 24rpx;
}

.field-group {
  margin-bottom: 28rpx;
}

.last-field {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #64748B;
  margin-bottom: 14rpx;
}

.picker-field,
.text-input,
.amount-input {
  height: 82rpx;
  border-radius: 14rpx;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  box-sizing: border-box;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.field-placeholder {
  font-size: 28rpx;
  color: #94A3B8;
}

.field-value {
  font-size: 28rpx;
  color: #111827;
}

.field-arrow {
  font-size: 32rpx;
  color: #CBD5E1;
}

.car-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
}

.car-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #111827;
}

.switch-car {
  font-size: 26rpx;
  color: #2563EB;
  font-weight: 700;
}

.text-input {
  width: 100%;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.amount-input {
  width: 100%;
  padding: 0 24rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
  color: #111827;
}

.save-btn {
  margin: 54rpx 28rpx 0;
  height: 90rpx;
  border-radius: 14rpx;
  background: #2F66F6;
  color: #FFF;
  font-size: 30rpx;
  font-weight: 900;
  border: none;
}

.safe-bottom {
  height: 44rpx;
  padding-bottom: env(safe-area-inset-bottom);
}
