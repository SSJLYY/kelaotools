/* 车辆信息页 - 样式 */
.x { display: none; }

/* 深色Hero区 */
.hero-section {
  padding-bottom: 32rpx;
}
.nav-bar {
  position: relative;
  z-index: 10;
}
.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}
.nav-back { width: 80rpx; }
.nav-right-btns { display: flex; gap: 24rpx; }
.nav-icon { font-size: 36rpx; color: rgba(255,255,255,0.7); padding: 8rpx; }

/* 车型名称 */
.hero-info {
  padding: 16rpx 28rpx 8rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.hero-model {
  font-size: 44rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}
.hero-year {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.5);
}

/* 配置标签 */
.hero-tags {
  display: flex;
  gap: 12rpx;
  padding: 0 28rpx 16rpx;
  align-items: center;
}
.hero-tag {
  padding: 6rpx 20rpx;
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.12);
  border-radius: 20rpx;
}
.hero-color-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 20rpx;
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.12);
  border-radius: 20rpx;
}
.color-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255,255,255,0.3);
}

/* 汽车图标 */
.hero-car-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 8rpx;
}
.hero-car-emoji { font-size: 140rpx; }
.hero-plate {
  margin-top: 12rpx;
  padding: 8rpx 28rpx;
  background: linear-gradient(135deg, #0066FF, #1E40AF);
  border-radius: 14rpx;
  border: 3rpx solid #60A5FA;
}
.plate-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #FFF;
  letter-spacing: 4rpx;
}

/* 三列统计 */
.hero-stats {
  display: flex;
  align-items: center;
  margin: 20rpx 28rpx 0;
  padding: 24rpx 0;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-lg);
}
.hero-stat {
  flex: 1;
  text-align: center;
}
.hero-stat-value {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
}
.hero-stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-top: 6rpx;
}

/* 参数区域 */
.spec-section {
  margin: 0 16rpx 16rpx;
  background: rgba(255,255,255,0.06);
  border-radius: var(--radius-lg);
  padding: 24rpx 20rpx;
}
.spec-section-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 18rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid var(--primary);
}

/* 参数网格 */
.spec-grid {
  display: flex;
  flex-wrap: wrap;
}
.spec-item {
  width: 25%;
  padding: 14rpx 6rpx;
  text-align: center;
  box-sizing: border-box;
}
.spec-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.40);
  display: block;
}
.spec-value {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-top: 6rpx;
  white-space: nowrap;
}

/* 功能快捷入口 */
.func-grid { display: flex; gap: 12rpx; }
.func-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-md);
  position: relative;
}
.func-item:active { background: rgba(255,255,255,0.14); }
.func-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.func-emoji { font-size: 36rpx; }
.func-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  font-weight: 500;
  margin-bottom: 4rpx;
}
.func-arrow {
  font-size: 24rpx;
  color: rgba(255,255,255,0.3);
}

/* 底部按钮 */
.bottom-btns {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.bottom-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  font-size: var(--font-md);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-edit {
  background: linear-gradient(135deg, #0066FF, #5B3FFF);
  color: #FFF;
}
.btn-delete {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.5);
}

/* ===== 深色模式 ===== */
.page.dark-mode {
  background: #121212 !important;
}

.dark-mode .nav-bar {
  background: transparent !important;
}

.dark-mode .card {
  background: #1E1E1E !important;
}

.dark-mode .param-label {
  color: #A0A0A0 !important;
}

.dark-mode .param-value {
  color: #E5E5E5 !important;
}
