/* 添加车辆 - 样式 */

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(245, 245, 247, 0.95);
  backdrop-filter: blur(20rpx);
}
.nav-content {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}
.nav-back {
  width: 80rpx;
}
.nav-back-icon {
  font-size: 52rpx;
  font-weight: 300;
  color: var(--text-primary);
  line-height: 1;
}
.nav-title-text {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.nav-right-placeholder {
  width: 80rpx;
}

/* 步骤指示器 */
.step-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 80rpx 24rpx;
}
.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.step-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
}
.step-active .step-circle {
  background: var(--primary);
  color: #FFF;
}
.step-check {
  font-size: 28rpx;
  color: #FFF;
}
.step-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}
.step-active .step-label {
  color: var(--primary);
  font-weight: 500;
}
.step-line {
  width: 80rpx;
  height: 3rpx;
  background: #E5E7EB;
  margin: 0 12rpx;
  margin-bottom: 24rpx;
}
.step-line-active {
  background: var(--primary);
}

/* 区域标题 */
.section-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  padding: 16rpx 28rpx 12rpx;
}

/* 车型选择网格 */
.model-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 24rpx;
}

.model-card {
  width: calc(50% - 8rpx);
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 3rpx solid transparent;
  position: relative;
  transition: all 0.2s;
}
.model-selected {
  border-color: var(--primary);
  background: var(--primary-light);
}

.model-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}
.model-emoji {
  font-size: 44rpx;
}
.model-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}
.model-sub {
  font-size: 20rpx;
  color: var(--text-light);
  display: block;
  margin-top: 6rpx;
}
.model-check-mark {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #FFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 已选车型标签 */
.selected-model-badge {
  display: flex;
  align-items: center;
  margin: 0 24rpx 20rpx;
  padding: 20rpx 24rpx;
  background: var(--primary-light);
  border-radius: var(--radius-md);
}
.badge-icon {
  font-size: 36rpx;
}
.badge-text {
  flex: 1;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--primary);
  margin-left: 12rpx;
}
.badge-change {
  font-size: var(--font-xs);
  color: var(--primary);
  padding: 6rpx 16rpx;
  background: #FFF;
  border-radius: var(--radius-sm);
}

/* 表单区域 */
.form-section {
  margin: 0 24rpx;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.form-item {
  padding: 24rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}
.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}
.form-label-sub {
  font-size: 20rpx;
  color: var(--text-light);
  display: block;
  margin-top: 4rpx;
}

/* 车牌输入 */
.plate-input-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.plate-province {
  width: 96rpx;
  height: 80rpx;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border: 2rpx solid transparent;
}
.plate-province-text {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--primary);
}
.plate-dropdown {
  font-size: 20rpx;
  color: var(--text-light);
}
.plate-input {
  flex: 1;
  height: 80rpx;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 4rpx;
  text-align: center;
}
.plate-placeholder {
  font-size: var(--font-sm);
  font-weight: 400;
  color: var(--text-placeholder);
  letter-spacing: 0;
}

/* 通用输入 */
.input-wrapper {
  display: flex;
  align-items: center;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
  padding-right: 16rpx;
}
.form-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: var(--font-md);
  color: var(--text-primary);
}
.input-focus {
  border-color: var(--primary);
}
.input-placeholder {
  color: var(--text-placeholder);
}
.input-placeholder-fallback {
  color: var(--text-placeholder);
}
.input-check {
  font-size: var(--font-md);
  color: var(--success);
  margin-right: 12rpx;
}
.input-scan {
  font-size: 36rpx;
  padding: 8rpx;
}
.input-arrow {
  font-size: 36rpx;
  color: #CCC;
}

.form-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 提示 */
.form-tip {
  display: flex;
  align-items: flex-start;
  margin: 24rpx;
  padding: 20rpx;
  background: #FEFCE8;
  border-radius: var(--radius-md);
  border: 1rpx solid #FDE68A;
}
.tip-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.tip-text {
  font-size: var(--font-xs);
  color: #92400E;
  line-height: 1.6;
  flex: 1;
}

/* 底部按钮 */
.bottom-btn-area {
  padding: 24rpx 28rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #0066FF, #5B3FFF);
  border-radius: var(--radius-full, 44rpx);
  font-size: var(--font-md);
  font-weight: 600;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
.btn-disabled {
  background: #D1D5DB;
  color: #9CA3AF;
}

/* 省份选择面板 */
.province-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.province-panel {
  width: 100%;
  background: #FFF;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 60vh;
}
.province-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.province-title {
  font-size: var(--font-md);
  font-weight: 600;
}
.province-close {
  font-size: 36rpx;
  color: var(--text-light);
  padding: 8rpx;
}
.province-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 20rpx;
  max-height: 50vh;
  overflow-y: auto;
}
.province-cell {
  width: calc(100% / 6);
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--font-md);
  border-radius: var(--radius-sm);
}
.province-cell-active {
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 600;
}
