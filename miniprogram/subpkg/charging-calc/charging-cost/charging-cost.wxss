/* ========================================
   充电费用计算 — 简约风格
   与全局设计系统统一
   ======================================== */

page {
  min-height: 100vh;
  background: var(--bg);
  color: var(--text-primary);
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 248, 250, 0.97);
  border-bottom: 1rpx solid var(--border-light);
}
.dark-mode .nav-bar {
  background: rgba(15, 15, 15, 0.97);
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 var(--space-lg);
}

.nav-back,
.nav-spacer {
  width: 90rpx;
}
.nav-back {
  font-size: 50rpx;
  line-height: 1;
  font-weight: 300;
  color: var(--text-primary);
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

/* 卡片容器 */
.calc-card,
.result-card,
.coupon-card {
  margin: var(--space-lg) 28rpx 0;
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-xl);
  box-sizing: border-box;
}

.calc-card {
  padding: 28rpx;
}

/* 车辆信息 */
.car-title {
  display: block;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.4;
}

.car-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: 600;
}

.meta-strong {
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 800;
}

/* 分割线 */
.card-line {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 字段 */
.field-label {
  display: block;
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: 700;
}

/* 电量输入区 */
.charge-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}

.charge-percent {
  color: var(--text-primary);
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.charge-input {
  width: 90rpx;
  height: 56rpx;
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: var(--font-md);
  font-weight: 800;
  text-align: center;
}

.charge-slider {
  margin: 18rpx 18rpx 0;
}

.target-section {
  margin-top: 28rpx;
}

/* 快捷目标按钮 */
.quick-row {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.quick-target {
  flex: 1;
  height: 64rpx;
  margin: 0;
  border: none;
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-secondary);
  font-size: var(--font-sm);
  font-weight: 700;
  line-height: 64rpx;
}
.quick-target::after {
  border: none;
}

.price-line {
  margin: 24rpx 0 22rpx;
}

/* 价格区 */
.price-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.preset-row {
  display: flex;
  gap: 10rpx;
}

.price-preset {
  min-width: 60rpx;
  height: 48rpx;
  margin: 0;
  padding: 0 12rpx;
  border: none;
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-secondary);
  font-size: var(--font-xs);
  font-weight: 700;
  line-height: 48rpx;
}
.price-preset::after {
  border: none;
}

.preset-active {
  background: var(--primary-light);
  color: var(--primary);
}

.price-input-wrap {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.price-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.price-unit {
  margin-left: 12rpx;
  color: var(--text-muted);
  font-size: var(--font-sm);
  font-weight: 700;
}

/* 充电损耗 */
.loss-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.loss-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toggle-switch {
  width: 84rpx;
  height: 46rpx;
  border-radius: 23rpx;
  background: #CBD5E1;
  position: relative;
  transition: background 0.2s;
}
.dark-mode .toggle-switch {
  background: #444;
}

.toggle-on {
  background: var(--warning);
}

.toggle-thumb {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #FFFFFF;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: left 0.2s;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
}

.toggle-on .toggle-thumb {
  left: 42rpx;
}

.loss-detail {
  margin-top: 18rpx;
}

.loss-presets {
  display: flex;
  gap: 10rpx;
}

.loss-preset-btn {
  flex: 1;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: var(--radius-md);
  background: var(--bg-input);
  color: var(--text-secondary);
  font-size: var(--font-xs);
  font-weight: 700;
  line-height: 48rpx;
}
.loss-preset-btn::after {
  border: none;
}

.loss-active {
  background: #FEF3C7;
  color: #D97706;
}
.dark-mode .loss-active {
  background: #2A2A1A;
  color: var(--warning);
}

.loss-slider-row {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}

.loss-slider {
  flex: 1;
  margin: 0;
}

.loss-input {
  width: 76rpx;
  height: 48rpx;
  border-radius: var(--radius-sm);
  background: var(--bg-input);
  color: var(--text-primary);
  font-size: var(--font-md);
  font-weight: 800;
  text-align: center;
}

.loss-unit {
  margin-left: 6rpx;
  color: var(--text-muted);
  font-size: var(--font-xs);
  font-weight: 700;
}

.loss-tip {
  display: block;
  margin-top: 12rpx;
  color: var(--text-muted);
  font-size: 20rpx;
  font-weight: 600;
}

/* 结果卡片 */
.result-card {
  height: 148rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.result-item {
  flex: 1;
  text-align: center;
}

.result-label {
  display: block;
  color: var(--text-muted);
  font-size: var(--font-sm);
  font-weight: 700;
}

.result-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-top: 14rpx;
}

.result-value {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}
.result-value.dark {
  color: var(--text-primary);
}
.result-value.blue {
  color: var(--primary);
}

.result-unit {
  margin-left: 4rpx;
  color: var(--text-secondary);
  font-size: var(--font-xs);
  font-weight: 700;
}

.result-divider {
  width: 2rpx;
  height: 72rpx;
  background: var(--border);
  margin: 0 28rpx;
}

/* 优惠券卡片 */
.coupon-card {
  padding: 24rpx 28rpx;
}

.coupon-title-row {
  display: flex;
  align-items: center;
}

.coupon-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.coupon-title {
  color: var(--text-primary);
  font-size: var(--font-md);
  font-weight: 800;
}

.coupon-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.coupon-chip {
  padding: 10rpx 16rpx;
  border-radius: var(--radius-sm);
  background: #FFF1F2;
  display: flex;
  align-items: baseline;
}
.dark-mode .coupon-chip {
  background: #2A1A1A;
}

.coupon-disabled {
  opacity: 0.45;
}

.coupon-name {
  color: var(--danger);
  font-size: var(--font-sm);
  font-weight: 800;
}

.coupon-pay {
  margin-left: 6rpx;
  color: var(--text-secondary);
  font-size: var(--font-xs);
  font-weight: 600;
}

.coupon-tip {
  display: block;
  margin-top: 18rpx;
  color: var(--text-muted);
  font-size: var(--font-xs);
  font-weight: 600;
}

.safe-bottom {
  height: 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
}