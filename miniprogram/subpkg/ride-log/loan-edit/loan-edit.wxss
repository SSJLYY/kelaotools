/* ===== 深色模式 ===== */
.page.dark-mode { background: #121212 !important; }
.dark-mode .nav-bar { background: rgba(15, 15, 15, 0.97) !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.page { min-height: 100vh; background: var(--bg); }
.nav-bar { position: fixed; left: 0; right: 0; z-index: 100; background: var(--bg); }
.nav-bar-inner { display: flex; align-items: center; padding: 0 16px; }
.nav-left, .nav-right { width: 60px; height: 44px; display: flex; align-items: center; }
.nav-icon { font-size: 20px; color: var(--text-primary); }
.nav-title { flex: 1; text-align: center; font-size: 17px; font-weight: 600; color: var(--text-primary); }
.form-card { margin: 16px; background: var(--bg-card); border-radius: 12px; padding: 16px; }
.form-item { margin-bottom: 16px; }
.form-label { font-size: 14px; color: var(--text-primary); margin-bottom: 8px; display: block; }
.form-input { width: 100%; height: 44px; border: 1rpx solid var(--border); border-radius: 8px; padding: 0 12px; font-size: 14px; box-sizing: border-box; }
.form-picker { height: 44px; border: 1rpx solid var(--border); border-radius: 8px; padding: 0 12px; display: flex; align-items: center; justify-content: space-between; font-size: 14px; color: var(--text-primary); }
.picker-arrow { font-size: 12px; color: var(--text-muted); }
.preview-card { margin: 0 16px 16px; background: #E6F0FF; border-radius: 12px; padding: 16px; display: flex; gap: 24px; }
.preview-item { flex: 1; text-align: center; }
.preview-label { font-size: 12px; color: var(--text-secondary); display: block; margin-bottom: 4px; }
.preview-value { font-size: 18px; font-weight: 600; color: var(--primary); }
.btn-area { padding: 0 16px; }
.btn-save { width: 100%; height: 48px; background: var(--primary); color: #fff; border: none; border-radius: 24px; font-size: 16px; font-weight: 600; }
