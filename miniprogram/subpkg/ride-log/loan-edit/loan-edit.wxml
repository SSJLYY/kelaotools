<view class="page" style="padding-top: {{navTotalHeight}}px;">
  <view class="nav-bar" style="top: 0; height: {{navTotalHeight}}px;">
    <view class="nav-bar-inner" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
      <view class="nav-left" bindtap="onBack"><text class="nav-icon">&larr;</text></view>
      <view class="nav-title">{{isEdit ? '编辑还款记录' : '添加还款记录'}}</view>
      <view class="nav-right"></view>
    </view>
  </view>

  <view class="form-card">
    <view class="form-item">
      <text class="form-label">还款期数 *</text>
      <picker mode="selector" range="{{periods}}" bindchange="onPeriodChange">
        <view class="form-picker">
          <text>{{formPeriod ? '第' + formPeriod + '期' : '请选择期数'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">还款金额 (元) *</text>
      <input class="form-input" type="digit" placeholder="请输入还款金额" value="{{formAmount}}" bindinput="onAmountInput" />
    </view>

    <view class="form-item">
      <text class="form-label">还款日期 *</text>
      <picker mode="date" value="{{formDate}}" bindchange="onDateChange">
        <view class="form-picker">
          <text>{{formDate}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">备注</text>
      <input class="form-input" placeholder="可选" value="{{formNote}}" bindinput="onNoteInput" />
    </view>
  </view>

  <!-- 实时预览 -->
  <view class="preview-card">
    <view class="preview-item">
      <text class="preview-label">已还总额</text>
      <text class="preview-value">¥{{totalPaid}}</text>
    </view>
    <view class="preview-item">
      <text class="preview-label">已还期数</text>
      <text class="preview-value">{{paidCount}}期</text>
    </view>
  </view>

  <view class="btn-area">
    <button class="btn-save" bindtap="onSave">{{isEdit ? '更新' : '保存'}}</button>
  </view>
</view>
