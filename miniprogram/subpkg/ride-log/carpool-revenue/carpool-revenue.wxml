<view class="page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack">‹</view>
      <view class="nav-title">{{mode === 'add' ? '快速添加' : '顺风车记录'}}</view>
      <view class="nav-spacer"></view>
    </view>
  </view>
  <view style="height: {{navTotalHeight}}px;"></view>

  <block wx:if="{{mode === 'list'}}">
    <view class="promo-card">
      <view class="promo-logo">↗</view>
      <view class="promo-main">
        <text class="promo-title">高德顺风车</text>
        <text class="promo-desc">适合上下班顺路接单，补一点充电和停车开销</text>
      </view>
      <button class="promo-btn" bindtap="onRegisterTap">立即注册</button>
    </view>
    <view class="promo-dots"><text class="dot active"></text><text class="dot"></text><text class="dot"></text><text class="dot"></text></view>

    <scroll-view class="platform-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="platform-list">
        <view
          wx:for="{{platforms}}"
          wx:key="key"
          class="platform-chip {{activePlatform === item.key ? 'chip-active' : ''}}"
          bindtap="onPlatformTap"
          data-platform="{{item.key}}"
        >{{item.name}}</view>
      </view>
    </scroll-view>

    <view class="section-header">
      <view>
        <text class="section-title">顺风车收入</text>
        <text class="section-sub">共 {{filteredRecords.length}} 笔收入</text>
      </view>
      <view class="header-actions">
        <button class="stats-btn" bindtap="showStats">统计</button>
        <button class="add-btn" bindtap="showAdd">+ 添加</button>
      </view>
    </view>

    <view class="record-list" wx:if="{{filteredRecords.length > 0}}">
      <view class="record-card" wx:for="{{filteredRecords}}" wx:key="id">
        <view class="record-icon" style="background: {{item.color}};">{{item.icon}}</view>
        <view class="record-main">
          <view class="record-title-row">
            <text class="record-title">{{item.platformName}}</text>
            <text class="route-text" wx:if="{{item.start || item.end}}">{{item.start || '起点'}} → {{item.end || '终点'}}</text>
          </view>
          <text class="record-note">{{item.note || item.carName || '暂无备注'}}</text>
          <text class="record-meta">{{item.mileage ? item.mileage + 'km · ' : ''}}{{item.date}}</text>
        </view>
        <view class="record-right">
          <text class="record-amount">¥{{item.revenueText}}</text>
          <text class="delete-link" bindtap="onDelete" data-id="{{item.id}}">删除</text>
          <text class="cost-text" wx:if="{{item.cost > 0}}">成本 ¥{{item.costText}}</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <view class="empty-car">🚙</view>
      <text class="empty-title">暂无收入记录</text>
      <text class="empty-sub">点击下方按钮添加第一笔收入</text>
    </view>

    <button class="float-add" bindtap="showAdd">+</button>
  </block>

  <block wx:else>
    <view class="form-title-row">
      <view>
        <text class="form-title">添加记录</text>
        <text class="form-sub">快速录入</text>
      </view>
      <text class="close-btn" bindtap="showList">×</text>
    </view>

    <view class="quick-platforms">
      <view
        wx:for="{{platformOptions}}"
        wx:key="key"
        class="quick-platform {{form.platform === item.key ? 'quick-active' : ''}}"
        bindtap="selectPlatform"
        data-platform="{{item.key}}"
      >
        <text class="quick-icon">{{item.icon}}</text>
        <text class="quick-name">{{item.name}}</text>
      </view>
    </view>

    <view class="form-card">
      <view class="field-group">
        <text class="field-label">接单日期</text>
        <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
          <view class="picker-field"><text class="field-value">{{form.date}}</text><text class="field-arrow">›</text></view>
        </picker>
      </view>

      <view class="field-group">
        <text class="field-label">平台</text>
        <picker range="{{platformOptions}}" range-key="name" value="{{platformIndex}}" bindchange="onPlatformChange">
          <view class="picker-field"><text class="field-value">{{form.platformName}}</text><text class="field-arrow">›</text></view>
        </picker>
      </view>

      <view class="field-group">
        <text class="field-label">关联车辆</text>
        <view class="car-row"><text class="car-name">{{form.carName}}</text><text class="switch-car" bindtap="onSwitchCar">切换</text></view>
      </view>

      <view class="field-group">
        <text class="field-label">收入金额（元）</text>
        <input class="amount-input" type="digit" value="{{form.amount}}" placeholder="0.00" bindinput="onAmountInput" />
      </view>

      <view class="route-row">
        <view class="route-field">
          <text class="field-label">行程起点</text>
          <input class="route-input" value="{{form.start}}" placeholder="选填" maxlength="20" bindinput="onStartInput" />
          <view class="tag-row">
            <text class="tag {{form.startTag === 'home' ? 'tag-active' : ''}}" bindtap="setStartTag" data-tag="home">家</text>
            <text class="tag {{form.startTag === 'company' ? 'tag-active' : ''}}" bindtap="setStartTag" data-tag="company">公司</text>
          </view>
        </view>
        <view class="route-field">
          <text class="field-label">行程终点</text>
          <input class="route-input" value="{{form.end}}" placeholder="选填" maxlength="20" bindinput="onEndInput" />
          <view class="tag-row">
            <text class="tag {{form.endTag === 'home' ? 'tag-active' : ''}}" bindtap="setEndTag" data-tag="home">家</text>
            <text class="tag {{form.endTag === 'company' ? 'tag-active' : ''}}" bindtap="setEndTag" data-tag="company">公司</text>
          </view>
        </view>
      </view>

      <view class="two-col-row">
        <view class="half-field">
          <text class="field-label">里程（公里）</text>
          <input class="text-input" type="digit" value="{{form.mileage}}" placeholder="0.0" bindinput="onMileageInput" />
        </view>
        <view class="half-field">
          <text class="field-label">油费/电费成本</text>
          <input class="text-input" type="digit" value="{{form.cost}}" placeholder="0.00" bindinput="onCostInput" />
        </view>
      </view>

      <view class="field-group last-field">
        <text class="field-label">备注</text>
        <input class="text-input" value="{{form.note}}" placeholder="最多50字（选填）" maxlength="50" bindinput="onNoteInput" />
      </view>
    </view>

    <button class="save-btn" bindtap="saveRecord">保存记录</button>
  </block>

  <view class="safe-bottom"></view>
</view>
