<!-- 车贷计算器 -->
<view style="padding:24rpx;min-height:100vh;background:#F5F5F7;">
  <view style="display:flex;align-items:center;margin-bottom:24rpx;">
    <text bindtap="onBack" style="font-size:48rpx;font-weight:300;">‹</text>
    <text style="font-size:34rpx;font-weight:700;flex:1;text-align:center;">车贷计算器</text>
    <view style="width:50rpx;"></view>
  </view>

  <view style="background:#FFF;border-radius:16rpx;padding:28rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,0.04);margin-bottom:24rpx;">
    <view style="margin-bottom:24rpx;"><text style="font-size:28rpx;font-weight:600;display:block;margin-bottom:8rpx;">贷款金额(元)</text><input style="background:#F5F5F7;border-radius:8rpx;padding:16rpx;font-size:28rpx;" type="digit" value="{{loanAmount}}" bindinput="onInput" data-field="loanAmount" placeholder="如：200000"/></view>
    <view style="margin-bottom:24rpx;"><text style="font-size:28rpx;font-weight:600;display:block;margin-bottom:8rpx;">年利率(%)</text><input style="background:#F5F5F7;border-radius:8rpx;padding:16rpx;font-size:28rpx;" type="digit" value="{{rate}}" bindinput="onInput" data-field="rate" placeholder="如：3.5"/></view>
    <view style="margin-bottom:24rpx;">
      <text style="font-size:28rpx;font-weight:600;display:block;margin-bottom:12rpx;">贷款期限</text>
      <view style="display:flex;gap:16rpx;">
        <view wx:for="{{terms}}" wx:key="*this" style="flex:1;text-align:center;padding:16rpx 0;border-radius:12rpx;border:3rpx solid {{months===item?'#0066FF':'#E5E7EB'}};background:{{months===item?'#E8F2FF':'#FFF'}};font-size:26rpx;font-weight:{{months===item?'700':'400'}};color:{{months===item?'#0066FF':'#666'}};" bindtap="onTermTap" data-v="{{item}}">{{item/12}}年</view>
      </view>
    </view>
    <button style="width:100%;height:88rpx;background:linear-gradient(135deg,#0066FF,#5B3FFF);border-radius:44rpx;border:none;color:#FFF;font-size:30rpx;font-weight:700;" bindtap="onCalc">计算</button>
  </view>

  <view wx:if="{{result}}" style="background:#FFF;border-radius:16rpx;padding:28rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,0.04);">
    <text style="font-size:28rpx;font-weight:700;display:block;margin-bottom:24rpx;">📊 计算结果</text>
    <view style="display:flex;gap:16rpx;margin-bottom:24rpx;">
      <view style="flex:1;text-align:center;padding:20rpx 0;background:#F0F4FF;border-radius:12rpx;">
        <text style="font-size:20rpx;color:#999;display:block;">月供</text>
        <text style="font-size:40rpx;font-weight:900;color:#0066FF;display:block;margin-top:4rpx;">¥{{result.monthly}}</text>
      </view>
      <view style="flex:1;text-align:center;padding:20rpx 0;background:#ECFDF5;border-radius:12rpx;">
        <text style="font-size:20rpx;color:#999;display:block;">总利息</text>
        <text style="font-size:40rpx;font-weight:900;color:#10B981;display:block;margin-top:4rpx;">¥{{result.totalInterest}}</text>
      </view>
    </view>
    <view style="display:flex;gap:16rpx;">
      <view style="flex:1;text-align:center;padding:20rpx 0;background:#FFF7ED;border-radius:12rpx;">
        <text style="font-size:20rpx;color:#999;display:block;">总还款</text>
        <text style="font-size:34rpx;font-weight:900;color:#F59E0B;display:block;margin-top:4rpx;">¥{{result.totalPayment}}</text>
      </view>
      <view style="flex:1;text-align:center;padding:20rpx 0;background:#FEF3C7;border-radius:12rpx;">
        <text style="font-size:20rpx;color:#999;display:block;">首付比例建议</text>
        <text style="font-size:28rpx;font-weight:700;color:#92400E;display:block;margin-top:4rpx;">≥30%</text>
      </view>
    </view>
  </view>
</view>
