<!-- 车贷还款记录 -->
<view class="{{darkMode ? 'dark-mode' : ''}}" style="min-height:100vh;background:{{darkMode ? '#121212' : '#F5F5F7'}};">
  <view class="nav" style="display:flex;align-items:center;padding:20rpx 24rpx;">
    <text bindtap="onBack" style="color:{{darkMode ? '#E8E8EC' : '#333'}};font-size:48rpx;font-weight:300;">‹</text>
    <text style="font-size:34rpx;font-weight:700;flex:1;text-align:center;color:{{darkMode ? '#E8E8EC' : '#333'}};">车贷还款记录</text>
    <view style="width:50rpx;"></view>
  </view>

  <view style="display:flex;margin:0 24rpx 16rpx;gap:16rpx;">
    <view style="flex:1;background:linear-gradient(135deg,#0066FF,#5B3FFF);border-radius:16rpx;padding:28rpx;text-align:center;">
      <text style="font-size:24rpx;color:rgba(255,255,255,0.7);display:block;">已还金额</text>
      <text style="font-size:48rpx;font-weight:900;color:#FFF;display:block;">¥{{totalPaid}}</text>
      <text style="font-size:20rpx;color:rgba(255,255,255,0.5);margin-top:4rpx;">{{paidCount}}期</text>
    </view>
  </view>

  <block wx:if="{{records.length>0}}">
    <view wx:for="{{records}}" wx:key="id" style="margin:0 24rpx 12rpx;background:{{darkMode ? '#1A1A1A' : '#FFF'}};border-radius:16rpx;padding:24rpx;">
      <view style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx;">
        <text style="font-size:28rpx;font-weight:700;color:{{darkMode ? '#E8E8EC' : '#333'}};">第{{item.period}}期</text>
        <text style="font-size:36rpx;font-weight:900;color:#0066FF;">¥{{item.amount}}</text>
      </view>
      <text style="font-size:22rpx;color:{{darkMode ? '#9CA3AF' : '#999'}};">还款日期：{{item.date}}　{{item.note||''}}</text>
    </view>
  </block>

  <view wx:if="{{records.length===0}}" style="text-align:center;padding:150rpx 48rpx;">
    <text style="font-size:100rpx;display:block;">💳</text>
    <text style="font-size:30rpx;font-weight:700;display:block;margin-top:24rpx;color:{{darkMode ? '#E8E8EC' : '#333'}};">暂无还款记录</text>
    <text style="font-size:24rpx;color:{{darkMode ? '#9CA3AF' : '#999'}};display:block;margin-top:12rpx;">记录每期车贷还款</text>
  </view>

  <view wx:if="{{showModal}}" class="modal-mask" bindtap="onCloseModal">
    <view class="modal-panel" catchtap="" style="background:{{darkMode ? '#1A1A1A' : '#FFF'}};border-radius:24rpx 24rpx 0 0;padding:32rpx 28rpx;padding-bottom:calc(32rpx+env(safe-area-inset-bottom));">
      <text style="font-size:32rpx;font-weight:700;display:block;margin-bottom:24rpx;color:{{darkMode ? '#E8E8EC' : '#333'}};">添加还款记录</text>
      <view style="margin-bottom:20rpx;"><text style="font-size:26rpx;font-weight:600;display:block;margin-bottom:8rpx;color:{{darkMode ? '#E8E8EC' : '#333'}};">期数</text><input style="background:{{darkMode ? '#262626' : '#F5F5F7'}};color:{{darkMode ? '#E8E8EC' : '#333'}};border-radius:8rpx;padding:14rpx;font-size:26rpx;" type="number" value="{{formPeriod}}" bindinput="onInputPeriod" placeholder="如：1"/></view>
      <view style="margin-bottom:20rpx;"><text style="font-size:26rpx;font-weight:600;display:block;margin-bottom:8rpx;color:{{darkMode ? '#E8E8EC' : '#333'}};">金额(元)</text><input style="background:{{darkMode ? '#262626' : '#F5F5F7'}};color:{{darkMode ? '#E8E8EC' : '#333'}};border-radius:8rpx;padding:14rpx;font-size:26rpx;" type="digit" value="{{formAmount}}" bindinput="onInputAmount" placeholder="如：6666"/></view>
      <view style="margin-bottom:20rpx;"><text style="font-size:26rpx;font-weight:600;display:block;margin-bottom:8rpx;color:{{darkMode ? '#E8E8EC' : '#333'}};">还款日期</text><picker mode="date" end="{{today}}" bindchange="onPickDate"><view style="background:{{darkMode ? '#262626' : '#F5F5F7'}};border-radius:8rpx;padding:14rpx;font-size:26rpx;color:{{formDate ? (darkMode ? '#E8E8EC' : '#1A1A2E') : (darkMode ? '#555' : '#CCC')}};">{{formDate||'请选择日期'}}</view></picker></view>
      <view style="margin-bottom:20rpx;"><text style="font-size:26rpx;font-weight:600;display:block;margin-bottom:8rpx;color:{{darkMode ? '#E8E8EC' : '#333'}};">备注(选填)</text><input style="background:{{darkMode ? '#262626' : '#F5F5F7'}};color:{{darkMode ? '#E8E8EC' : '#333'}};border-radius:8rpx;padding:14rpx;font-size:26rpx;" value="{{formNote}}" bindinput="onInputNote" placeholder="如：提前还款"/></view>
      <button class="primary-btn" bindtap="onSave" style="width:100%;height:88rpx;background:linear-gradient(135deg,#0066FF,#5B3FFF);border-radius:44rpx;border:none;color:#FFF;font-size:28rpx;font-weight:700;margin-top:16rpx;">保存</button>
      <text style="text-align:center;color:{{darkMode ? '#9CA3AF' : '#999'}};font-size:24rpx;display:block;margin-top:16rpx;" bindtap="onCloseModal">取消</text>
    </view>
  </view>

  <view style="position:fixed;bottom:120rpx;right:32rpx;z-index:50;width:100rpx;height:100rpx;border-radius:50%;background:linear-gradient(135deg,#0066FF,#5B3FFF);box-shadow:0 8rpx 24rpx rgba(0,102,255,0.35);display:flex;align-items:center;justify-content:center;" bindtap="onAdd"><text style="font-size:48rpx;color:#FFF;">＋</text></view>
  <view style="height:80rpx;"></view>
</view>