<!-- 个人中心 -->
<view class="page {{darkMode ? 'dark-mode' : ''}}" style="min-height:100vh;">

  <!-- 用户信息卡片 -->
  <view class="user-hero" bindtap="onGoProfile">
    <view class="hero-top">
      <image src="{{userAvatar}}" mode="aspectFill" class="hero-avatar" />
      <view class="hero-info">
        <view class="hero-name-row">
          <text class="hero-name">{{userName}}</text>
          <text class="hero-tag">永久免费</text>
        </view>
        <text class="hero-sub">氪佬工具箱 · 极氪车主专属</text>
      </view>
      <text class="hero-arrow">›</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stat-row">
    <view class="stat-item"><text class="stat-val">{{chargingCount}}</text><text class="stat-label">充电记录</text></view>
    <view class="stat-divider"></view>
    <view class="stat-item"><text class="stat-val">{{mileageCount}}</text><text class="stat-label">里程记录</text></view>
    <view class="stat-divider"></view>
    <view class="stat-item"><text class="stat-val">{{maintenanceCount}}</text><text class="stat-label">养车记录</text></view>
    <view class="stat-divider"></view>
    <view class="stat-item"><text class="stat-val">{{carpoolCount}}</text><text class="stat-label">出行记录</text></view>
  </view>

  <!-- 快捷设置 -->
  <view class="menu-card">
    <view class="menu-card-title">⚡ 快捷设置</view>
    <view class="menu-item" bindtap="onOpenDarkModeSetting">
      <view class="menu-left">
        <text class="menu-icon">🌙</text>
        <text>深色模式</text>
      </view>
      <view class="menu-right">
        <text class="menu-val">{{darkModeSetting.mode === 'auto' ? '自动' : darkModeSetting.mode === 'dark' ? '深色' : '浅色'}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="onSwitchLang">
      <view class="menu-left">
        <text class="menu-icon">🌐</text>
        <text>切换语言</text>
      </view>
      <text class="menu-val">{{currentLang}}</text>
    </view>
  </view>

  <!-- 记录工具 -->
  <view class="menu-card">
    <view class="menu-card-title">📝 记录工具</view>
    <view class="menu-item" bindtap="onNav" data-path="/subpkg/charging-log/charging-log/charging-log"><text>⚡ 充电记录</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/mileage-log/mileage-log"><text>🛣️ 里程记录</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/subpkg/maintenance/maintenance-ledger/maintenance-ledger"><text>🔧 养车账本</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/subpkg/ride-log/carpool-revenue/carpool-revenue"><text>🚘 顺风车收入</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/car-wash/car-wash"><text>🚿 洗车日记</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/modification/modification"><text>🏎️ 改装配件</text><text class="menu-arrow">›</text></view>
  </view>

  <!-- 工具与设置 -->
  <view class="menu-card">
    <view class="menu-card-title">🛠️ 工具与设置</view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/maintenance-reminder/maintenance-reminder"><text>🔧 保养提醒</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/charging-station/charging-station"><text>⚡ 充电站收藏</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/price-trend/price-trend"><text>📈 电价走势</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/station-review/station-review"><text>⭐ 充电站评价</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/data-export/data-export"><text>📤 数据导出</text><text class="menu-arrow">›</text></view>
  </view>

  <!-- 数据与统计 -->
  <view class="menu-card">
    <view class="menu-card-title">📊 数据与统计</view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/data-statistics/data-statistics"><text>📊 数据统计</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/monthly-report/monthly-report"><text>📋 月度报告</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/favorites/favorites"><text>⭐ 我的收藏</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onNav" data-path="/pages/car-community/car-community"><text>💬 车主社区</text><text class="menu-arrow">›</text></view>
  </view>

  <!-- 更多 -->
  <view class="menu-card">
    <view class="menu-card-title">⚙️ 更多</view>
    <view class="menu-item" bindtap="onGoFeatureIntro"><text>📖 功能介绍</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onGoAddDesktopGuide"><text>📲 添加到桌面</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onSwitchLang"><text>🌐 切换语言</text><text class="menu-val">{{currentLang}}</text></view>
    <view class="menu-item" bindtap="onGoChangelog"><text>📋 更新日志</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onCheckUpdate"><text>🔄 检查更新</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onFeedback"><text>💬 意见反馈</text><text class="menu-arrow">›</text></view>
    <view class="menu-item" bindtap="onAbout"><text>ℹ️ 关于我们</text><text class="menu-arrow">›</text></view>
  </view>

  <view class="version-text">
    <text>{{appVersion}}</text>
  </view>
  <view class="safe-bottom"></view>

  <!-- 深色模式设置弹窗 -->
  <view class="dm-popup-mask" wx:if="{{showDarkModePopup}}" bindtap="onCloseDarkModePopup"></view>
  <view class="dm-popup {{showDarkModePopup ? 'dm-popup-show' : ''}}" catchtap="">
    <view class="dm-popup-header">
      <text class="dm-popup-title">深色模式设置</text>
      <text class="dm-popup-close" bindtap="onCloseDarkModePopup">✕</text>
    </view>

    <view class="dm-mode-list">
      <view class="dm-mode-item {{darkModeSetting.mode === 'light' ? 'dm-mode-active' : ''}}" bindtap="onSetDarkMode" data-mode="light">
        <view class="dm-mode-icon">☀️</view>
        <view class="dm-mode-text">
          <text class="dm-mode-name">浅色模式</text>
          <text class="dm-mode-desc">始终使用浅色界面</text>
        </view>
        <view class="dm-mode-check" wx:if="{{darkModeSetting.mode === 'light'}}">✓</view>
      </view>
      <view class="dm-mode-item {{darkModeSetting.mode === 'dark' ? 'dm-mode-active' : ''}}" bindtap="onSetDarkMode" data-mode="dark">
        <view class="dm-mode-icon">🌙</view>
        <view class="dm-mode-text">
          <text class="dm-mode-name">深色模式</text>
          <text class="dm-mode-desc">始终使用深色界面</text>
        </view>
        <view class="dm-mode-check" wx:if="{{darkModeSetting.mode === 'dark'}}">✓</view>
      </view>
      <view class="dm-mode-item {{darkModeSetting.mode === 'auto' ? 'dm-mode-active' : ''}}" bindtap="onSetDarkMode" data-mode="auto">
        <view class="dm-mode-icon">⏰</view>
        <view class="dm-mode-text">
          <text class="dm-mode-name">自动切换</text>
          <text class="dm-mode-desc">按时段自动切换浅色/深色</text>
        </view>
        <view class="dm-mode-check" wx:if="{{darkModeSetting.mode === 'auto'}}">✓</view>
      </view>
    </view>

    <view class="dm-time-section" wx:if="{{darkModeSetting.mode === 'auto'}}">
      <view class="dm-time-row">
        <text class="dm-time-label">🌙 切换深色时间</text>
        <view class="dm-time-pickers">
          <picker mode="selector" range="{{darkHourRange}}" value="{{darkModeSetting.darkHour}}" bindchange="onDarkHourChange">
            <view class="dm-time-picker">{{darkHourRange[darkModeSetting.darkHour]}}</view>
          </picker>
          <text class="dm-time-colon">:</text>
          <picker mode="selector" range="{{darkMinuteRange}}" value="{{darkModeSetting.darkMinute}}" bindchange="onDarkMinuteChange">
            <view class="dm-time-picker">{{darkMinuteRange[darkModeSetting.darkMinute]}}</view>
          </picker>
        </view>
      </view>
      <view class="dm-time-row">
        <text class="dm-time-label">☀️ 切换浅色时间</text>
        <view class="dm-time-pickers">
          <picker mode="selector" range="{{lightHourRange}}" value="{{darkModeSetting.lightHour}}" bindchange="onLightHourChange">
            <view class="dm-time-picker">{{lightHourRange[darkModeSetting.lightHour]}}</view>
          </picker>
          <text class="dm-time-colon">:</text>
          <picker mode="selector" range="{{lightMinuteRange}}" value="{{darkModeSetting.lightMinute}}" bindchange="onLightMinuteChange">
            <view class="dm-time-picker">{{lightMinuteRange[darkModeSetting.lightMinute]}}</view>
          </picker>
        </view>
      </view>
    </view>

    <button class="dm-popup-confirm" bindtap="onConfirmDarkModeSetting">确定</button>
  </view>
</view>
