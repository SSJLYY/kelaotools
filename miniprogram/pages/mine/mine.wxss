/* 个人中心 */
.user-hero { background:linear-gradient(135deg,#0066FF,#5B3FFF);padding:48rpx 24rpx 40rpx; }
.hero-top { display:flex;align-items:center; }
.hero-avatar { width:110rpx;height:110rpx;border-radius:50%;border:4rpx solid rgba(255,255,255,0.4); }
.hero-info { flex:1;margin-left:24rpx; }
.hero-name-row { display:flex;align-items:center;gap:12rpx; }
.hero-name { font-size:36rpx;font-weight:700;color:#FFF; }
.hero-tag { font-size:18rpx;color:#FFF;background:rgba(255,255,255,0.2);padding:4rpx 14rpx;border-radius:20rpx; }
.hero-sub { font-size:24rpx;color:rgba(255,255,255,0.7);margin-top:6rpx;display:block; }
.hero-arrow { font-size:40rpx;color:rgba(255,255,255,0.5); }

.stat-row { display:flex;background:#FFF;margin:0 24rpx;border-radius:16rpx;margin-top:-20rpx;padding:28rpx 0;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.06);position:relative;z-index:1; }
.stat-item { flex:1;text-align:center; }
.stat-val { font-size:40rpx;font-weight:800;color:#1A1A2E;display:block; }
.stat-label { font-size:20rpx;color:#999;margin-top:6rpx;display:block; }
.stat-divider { width:1rpx;height:48rpx;background:#F0F0F0;align-self:center; }

.menu-card { margin:20rpx 24rpx;background:#FFF;border-radius:16rpx;overflow:hidden; }
.menu-card-title { font-size:24rpx;font-weight:600;color:#999;padding:20rpx 24rpx 8rpx;border-bottom:1rpx solid #F5F5F5; }
.menu-item { display:flex;align-items:center;justify-content:space-between;padding:26rpx 24rpx;border-bottom:1rpx solid #F5F5F5;font-size:var(--font-md);color:var(--text-primary); }
.menu-item:last-child { border-bottom:none; }
.menu-arrow { font-size:28rpx;color:#CCC; }
.menu-val { font-size:var(--font-sm);color:#999; }
