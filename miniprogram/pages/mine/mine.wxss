/* ========================================
   个人中心 — 简约风格
   所有颜色通过 CSS 变量自动适配深色模式
   ======================================== */

/* ===== 用户头部 ===== */
.user-hero {
  background: var(--primary-gradient);
  padding: 48rpx var(--space-lg) 40rpx;
}

.hero-top {
  display: flex;
  align-items: center;
}

.hero-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.hero-info {
  flex: 1;
  margin-left: var(--space-lg);
}

.hero-name-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.hero-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #FFFFFF;
}

.hero-tag {
  font-size: 18rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}

.hero-sub {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.65);
  margin-top: 6rpx;
  display: block;
}

.hero-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== 数据统计 ===== */
.stat-row {
  display: flex;
  background: var(--bg-card);
  margin: 0 var(--space-lg);
  border-radius: var(--radius-lg);
  margin-top: -20rpx;
  padding: 24rpx 0;
  box-shadow: var(--shadow-md);
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-val {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--border);
  align-self: center;
}

/* ===== 菜单卡片 ===== */
.menu-card {
  margin: 16rpx var(--space-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-card-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-muted);
  padding: 18rpx var(--space-lg) 8rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx var(--space-lg);
  border-bottom: 1rpx solid var(--border-light);
  font-size: var(--font-md);
  color: var(--text-primary);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item:active {
  background: var(--bg-card-hover);
}

.menu-left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.menu-icon {
  font-size: 28rpx;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCC;
}
.dark-mode .menu-arrow {
  color: #555;
}

.menu-val {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* ===== 深色模式弹窗 ===== */
.dm-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.dm-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 0 var(--space-xl) 48rpx;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.dm-popup-show {
  transform: translateY(0);
}

.dm-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-xl) 0 var(--space-lg);
}

.dm-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.dm-popup-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: var(--space-xs);
}

.dm-mode-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
}

.dm-mode-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius-lg);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.dm-mode-active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.dm-mode-icon {
  font-size: 36rpx;
  margin-right: 18rpx;
}

.dm-mode-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.dm-mode-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.dm-mode-desc {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: 4rpx;
}

.dm-mode-check {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 700;
}

.dm-time-section {
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-xl);
}

.dm-time-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}
.dm-time-row:first-child {
  padding-top: 0;
}
.dm-time-row + .dm-time-row {
  border-top: 1rpx solid var(--border);
}

.dm-time-label {
  font-size: var(--font-md);
  color: var(--text-primary);
}

.dm-time-pickers {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.dm-time-picker {
  background: var(--bg-card);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 6rpx 18rpx;
  font-size: var(--font-md);
  color: var(--text-primary);
  min-width: 64rpx;
  text-align: center;
}

.dm-time-colon {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 600;
}

.dm-popup-confirm {
  width: 100%;
  height: 88rpx;
  background: var(--primary);
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-lg);
  font-weight: 600;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 底部版本号 */
.version-text {
  text-align: center;
  padding: 40rpx 0;
  font-size: var(--font-xs);
  color: var(--text-placeholder);
}