<view class="page {{darkMode ? 'dark-mode' : ''}}">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack">‹</view>
      <view class="nav-title">我的收藏</view>
      <view class="nav-spacer"></view>
    </view>
  </view>
  <view style="height: {{navTotalHeight}}px;"></view>

  <view class="summary-card">
    <view class="summary-main">
      <text class="summary-label">当前收藏</text>
      <view class="summary-count-row">
        <text class="summary-count">{{favoriteStats.total}}</text>
        <text class="summary-unit">项</text>
      </view>
      <text class="summary-tip">常用内容会按收藏时间排序，方便快速复制</text>
    </view>
    <view class="summary-side">
      <view class="summary-pill"><text>场景码</text><text>{{favoriteStats.scene}}</text></view>
      <view class="summary-pill"><text>音效</text><text>{{favoriteStats.sound}}</text></view>
    </view>
  </view>

  <view class="tab-row">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-chip {{activeTab === item.key ? 'tab-active' : ''}}"
      bindtap="onTabTap"
      data-key="{{item.key}}"
    >{{item.name}}<text class="tab-count">{{item.count || 0}}</text></view>
  </view>

  <view class="favorite-list" wx:if="{{filteredFavorites.length > 0}}">
    <view class="favorite-card" wx:for="{{filteredFavorites}}" wx:key="uid" bindtap="onItemTap" data-type="{{item.type}}" data-id="{{item.id}}">
      <view class="favorite-icon">{{item.icon}}</view>
      <view class="favorite-main">
        <view class="favorite-title-row">
          <text class="favorite-title">{{item.title}}</text>
          <text class="favorite-type">{{item.typeName}}</text>
        </view>
        <text class="favorite-desc">{{item.desc}}</text>
        <view class="favorite-meta-row">
          <text class="favorite-code">{{item.code}}</text>
          <text class="favorite-dot">·</text>
          <text class="favorite-time">{{item.timeText}}</text>
        </view>
        <view class="favorite-tags">
          <text class="favorite-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
      </view>
      <view class="favorite-actions">
        <button class="copy-btn" catchtap="onCopy" data-code="{{item.code}}">复制</button>
        <text class="remove-link" catchtap="onRemove" data-type="{{item.type}}" data-id="{{item.id}}">取消</text>
      </view>
    </view>
  </view>

  <view class="empty-card" wx:else>
    <view class="empty-icon">★</view>
    <text class="empty-title">{{emptyTitle}}</text>
    <text class="empty-sub">{{emptySub}}</text>
    <button class="empty-action" bindtap="onGoExplore">去收藏</button>
  </view>

  <view class="safe-bottom"></view>
</view>
