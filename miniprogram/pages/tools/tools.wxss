/* ========================================
   场景码列表页 — 简约风格
   所有颜色通过 CSS 变量自动适配深色模式
   ======================================== */

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 248, 250, 0.97);
  border-bottom: 1rpx solid var(--border-light);
}
.dark-mode .nav-bar {
  background: rgba(15, 15, 15, 0.97);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-lg);
}

.nav-title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 搜索栏 */
.search-bar {
  padding: var(--space-md) var(--space-lg);
}

.search-input-box {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-full);
  padding: 16rpx var(--space-lg);
  border: 1rpx solid var(--border);
}

.search-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
  opacity: 0.5;
}

.search-placeholder {
  font-size: var(--font-sm);
  color: var(--text-placeholder);
}

/* 分类标签 */
.category-scroll {
  width: 100%;
  margin-bottom: var(--space-xs);
}

.category-list {
  display: flex;
  gap: var(--space-sm);
  padding: var(--space-xs) var(--space-lg) var(--space-sm);
  white-space: nowrap;
}

.category-tag {
  flex-shrink: 0;
  padding: 10rpx 26rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  background: var(--bg-card);
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border);
  transition: all 0.2s;
}

.tag-active {
  background: var(--primary);
  color: #FFFFFF;
  border-color: var(--primary);
  font-weight: 600;
}

/* 提示条 */
.scene-tip {
  display: flex;
  align-items: center;
  margin: 0 var(--space-lg) var(--space-sm);
  padding: 14rpx 18rpx;
  background: #FFFBF0;
  border-radius: var(--radius-md);
  border: 1rpx solid #FDE68A;
}
.dark-mode .scene-tip {
  background: #2A2A1A;
  border-color: #4A4A2A;
}

.scene-tip-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.scene-tip-text {
  font-size: 20rpx;
  color: #92400E;
  line-height: 1.6;
}
.dark-mode .scene-tip-text {
  color: var(--warning);
}

/* 场景码列表 */
.scene-list {
  padding: 0 var(--space-lg);
}

.scene-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-sm);
}
.scene-card:active {
  background: var(--bg-card-hover);
}

.scene-card-left {
  flex: 1;
  overflow: hidden;
  margin-right: 18rpx;
}

.scene-card-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.scene-card-desc {
  font-size: var(--font-xs);
  color: var(--text-muted);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.scene-card-tags {
  display: flex;
  gap: var(--space-xs);
}

.scene-tag {
  padding: 2rpx 14rpx;
  font-size: 20rpx;
  color: var(--primary);
  background: var(--primary-light);
  border-radius: var(--radius-full);
}

.scene-card-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.scene-code-badge {
  padding: 8rpx 18rpx;
  background: var(--primary-light);
  border-radius: var(--radius-sm);
  margin-bottom: 10rpx;
}

.scene-code-num {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: 2rpx;
}

.scene-copy-btn {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
  background: var(--primary-light);
  border: none;
  border-radius: var(--radius-full);
  padding: 6rpx 22rpx;
  line-height: 1.6;
}