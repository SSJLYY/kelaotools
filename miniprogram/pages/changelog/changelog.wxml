<view class="page {{darkMode ? 'dark-mode' : ''}}" style="padding-top: {{navTotalHeight}}px;">
  <view class="nav-bar" style="top: 0; height: {{navTotalHeight}}px;">
    <view class="nav-bar-inner" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
      <view class="nav-left" bindtap="onBack"><text class="nav-icon">←</text></view>
      <view class="nav-title">更新日志</view>
      <view class="nav-right"></view>
    </view>
  </view>

  <view class="timeline">
    <view wx:for="{{versions}}" wx:key="version" class="version-card">
      <view class="version-dot {{index === 0 ? 'dot-active' : ''}}"></view>
      <view class="version-line" wx:if="{{index < versions.length - 1}}"></view>
      <view class="version-content">
        <view class="version-header">
          <text class="version-number">{{item.version}}</text>
          <text class="version-date">{{item.date}}</text>
        </view>
        <view class="changes-list">
          <block wx:if="{{item.categories}}">
            <view wx:for="{{item.categories}}" wx:key="name" wx:for-item="cat" class="change-category">
              <text class="category-title">{{cat.name}}</text>
              <view wx:for="{{cat.items}}" wx:key="*this" wx:for-item="ci" class="change-item">
                <text class="change-dot">•</text>
                <text class="change-text">{{ci}}</text>
              </view>
            </view>
          </block>
          <block wx:else>
            <view wx:for="{{item.changes}}" wx:key="*this" wx:for-item="change" class="change-item">
              <text class="change-dot">•</text>
              <text class="change-text">{{change}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>

  <view style="height: 60rpx;"></view>
</view>
