/* ===== 深色模式 ===== */
.page.dark-mode { background: #121212 !important; }
.dark-mode .nav-bar { background: #1a1a1a !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.page { min-height: 100vh; background: var(--bg); }
.nav-bar { position: fixed; left: 0; right: 0; z-index: 100; background: var(--bg); }
.nav-bar-inner { display: flex; align-items: center; padding: 0 16px; }
.nav-left, .nav-right { width: 60px; height: 44px; display: flex; align-items: center; }
.nav-icon { font-size: 20px; color: var(--text-primary); }
.nav-title { flex: 1; text-align: center; font-size: 17px; font-weight: 600; color: var(--text-primary); }
.timeline { padding: 16px 16px 0 32px; position: relative; }
.version-card { position: relative; padding-left: 24px; padding-bottom: 24px; }
.version-dot { position: absolute; left: -8px; top: 6px; width: 12px; height: 12px; border-radius: 50%; background: #ddd; border: 2px solid #fff; z-index: 1; }
.dot-active { background: #0066FF; box-shadow: 0 0 0 4px rgba(0,102,255,0.2); }
.version-line { position: absolute; left: -3px; top: 20px; bottom: 0; width: 2px; background: #E5E7EB; }
.version-content { background: var(--bg-card); border-radius: 12px; padding: 16px; }
.version-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.version-number { font-size: 18px; font-weight: 700; color: var(--text-primary); }
.version-date { font-size: 13px; color: var(--text-muted); }
.changes-list { display: flex; flex-direction: column; gap: 6px; }
.change-category { margin-bottom: 10px; }
.change-category:last-child { margin-bottom: 0; }
.category-title { font-size: 14px; font-weight: 600; color: #0066FF; margin-bottom: 6px; display: block; }
.change-item { display: flex; align-items: flex-start; gap: 8px; }
.change-dot { color: #0066FF; font-size: 14px; line-height: 20px; flex-shrink: 0; }
.change-text { font-size: 14px; color: #555; line-height: 20px; }

/* ===== 深色模式补充 ===== */
.dark-mode .nav-title-text { color: #E5E5E5 !important; }
.dark-mode .nav-icon { color: #E5E5E5 !important; }
.dark-mode .version-dot { background: #444444 !important; border-color: #1E1E1E !important; }
.dark-mode .dot-active { background: #0066FF !important; border-color: #1E1E1E !important; }
.dark-mode .version-line { background: #333333 !important; }
.dark-mode .version-content { background: #1E1E1E !important; border-color: #333333 !important; }
.dark-mode .version-number { color: #E5E5E5 !important; }
.dark-mode .version-date { color: #A0A0A0 !important; }
.dark-mode .change-dot { color: #4D94FF !important; }
.dark-mode .change-text { color: #A0A0A0 !important; }
.dark-mode .category-title { color: #4D94FF !important; }
