<view class="page {{darkMode ? 'dark-mode' : ''}}">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack">‹</view>
      <view class="nav-title">功能介绍</view>
      <view class="nav-spacer"></view>
    </view>
  </view>
  <view style="height: {{navTotalHeight}}px;"></view>

  <view class="header">
    <text class="page-title">功能介绍</text>
    <text class="page-sub">专为极氪车主打造的免费工具合集</text>
  </view>

  <view class="feature-list">
    <view class="feature-card" wx:for="{{features}}" wx:key="title">
      <view class="feature-top" bindtap="onFeatureTap" data-index="{{index}}">
        <view class="feature-icon">{{item.icon}}</view>
        <view class="feature-main">
          <view class="title-row">
            <text class="feature-title">{{item.title}}</text>
            <text class="feature-arrow">›</text>
          </view>
          <text class="feature-desc">{{item.desc}}</text>
        </view>
      </view>

      <view class="tag-list">
        <text class="feature-tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
      </view>

      <view class="action-row">
        <button class="action-btn" bindtap="onFeatureTap" data-index="{{index}}">{{item.action}}</button>
      </view>
    </view>
  </view>

  <view class="footer-tip">
    <view class="footer-line"></view>
    <text>全部功能免费使用，持续更新中</text>
  </view>

  <view class="safe-bottom"></view>
</view>
