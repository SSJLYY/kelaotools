/* 用车小贴士 */
.nav-bar { position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.97);border-bottom:1rpx solid rgba(0,0,0,0.05); }
.nav-content { display:flex;align-items:center;padding:0 24rpx; }
.nav-back { width:80rpx; }
.nav-back-icon { font-size:48rpx;font-weight:300;color:var(--text-primary); }
.nav-title-text { flex:1;text-align:center;font-size:34rpx;font-weight:600; }
.category-scroll { margin-bottom:8rpx; }
.category-list { display:flex;gap:12rpx;padding:8rpx 24rpx 16rpx;white-space:nowrap; }
.category-tag { flex-shrink:0;padding:12rpx 28rpx;font-size:var(--font-xs);color:var(--text-secondary);background:#FFF;border-radius:36rpx;border:2rpx solid var(--border-color); }
.tag-active { background:var(--primary);color:#FFF;border-color:var(--primary);font-weight:600; }
.tips-list { padding:0 24rpx; }
.tip-card { background:#FFF;border-radius:var(--radius-lg);padding:24rpx 20rpx;margin-bottom:16rpx;box-shadow:var(--shadow-sm); }
.tip-card:active { background:#FAFAFA; }
.tip-top { display:flex;align-items:flex-start; }
.tip-icon-box { width:72rpx;height:72rpx;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;flex-shrink:0; }
.tip-emoji { font-size:36rpx; }
.tip-info { margin-left:18rpx;flex:1;overflow:hidden; }
.tip-title { font-size:var(--font-md);font-weight:700;color:var(--text-primary);display:block;margin-bottom:6rpx; }
.tip-summary { font-size:var(--font-xs);color:var(--text-secondary);line-height:1.5;display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;overflow:hidden; }
.tip-bottom { display:flex;gap:8rpx;margin-top:16rpx;padding-top:14rpx;border-top:1rpx solid var(--border-light); }
.tip-tag { padding:2rpx 14rpx;font-size:20rpx;color:var(--primary);background:var(--primary-light);border-radius:20rpx; }
