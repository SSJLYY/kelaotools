/* ===== 深色模式 ===== */
.page.dark-mode { background: #121212 !important; }
.dark-mode .nav-bar { background: rgba(15, 15, 15, 0.97) !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.dark-mode .nav-icon { color: #E5E5E5 !important; }
.dark-mode .reminder-status.normal { color: #10B981 !important; background: #1a2a1a !important; }
.dark-mode .reminder-status.urgent { color: #F59E0B !important; background: #2a2a1a !important; }
.dark-mode .reminder-status.overdue { color: #EF4444 !important; background: #2a1a1a !important; }
.dark-mode .reminder-type { color: #E5E5E5 !important; }
.dark-mode .date-label { color: #A0A0A0 !important; }
.dark-mode .date-value { color: #E5E5E5 !important; }
.dark-mode .date-arrow { color: #666666 !important; }
.dark-mode .interval-text { color: #A0A0A0 !important; }
.dark-mode .reminder-note { color: #A0A0A0 !important; border-top-color: #333333 !important; }
.dark-mode .reminder-actions { border-top-color: #333333 !important; }
.dark-mode .form-title { color: #E5E5E5 !important; }
.dark-mode .form-label { color: #E5E5E5 !important; }
.page {
  min-height: 100vh;
  background: var(--bg);
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: var(--text-primary);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}

.content {
  padding: 16px;
}

/* 紧急提醒横幅 */
.urgent-banner {
  background: #FEF2F2;
  border: 1px solid #FECACA;
  border-radius: 8px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.urgent-icon {
  font-size: 16px;
}

.urgent-text {
  font-size: 14px;
  color: #DC2626;
  font-weight: 500;
}

/* 提醒列表 */
.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.reminder-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 16px;
  border-left: 4px solid #10B981;
}

.reminder-card.urgent {
  border-left-color: #F59E0B;
}

.reminder-card.overdue {
  border-left-color: #EF4444;
}

.reminder-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.reminder-type {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.reminder-status {
  font-size: 13px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 4px;
}

.reminder-status.normal {
  color: #10B981;
  background: #D1FAE5;
}

.reminder-status.urgent {
  color: #F59E0B;
  background: #FEF3C7;
}

.reminder-status.overdue {
  color: #EF4444;
  background: #FEE2E2;
}

.reminder-main {
  margin-bottom: 12px;
}

.reminder-dates {
  display: flex;
  align-items: center;
  gap: 12px;
}

.date-item {
  flex: 1;
}

.date-label {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.date-value {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
}

.date-arrow {
  font-size: 16px;
  color: #ccc;
}

.reminder-interval {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.interval-text {
  color: var(--text-secondary);
}

.reminder-note {
  font-size: 12px;
  color: var(--text-muted);
  padding-top: 8px;
  border-top: 1rpx solid var(--border);
  margin-bottom: 8px;
}

.reminder-actions {
  display: flex;
  gap: 12px;
  padding-top: 12px;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  flex: 1;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
}

.done-btn {
  background: #10B981;
  color: #fff;
}

.delete-btn {
  background: #FEE2E2;
  color: #EF4444;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: var(--text-muted);
  margin-bottom: 24px;
}

.empty-btn {
  background: var(--primary);
  color: #fff;
  padding: 10px 24px;
  border-radius: 8px;
  font-size: 15px;
}

/* 表单 */
.form-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 20px;
}

.form-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20px;
  text-align: center;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 8px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-picker {
  height: 44px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 14px;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 12px;
  color: var(--text-muted);
}

.form-textarea {
  width: 100%;
  height: 80px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-btns {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 15px;
}

.btn-cancel {
  background: var(--bg-input);
  color: var(--text-secondary);
}

.btn-save {
  background: var(--primary);
  color: #fff;
}
