.page {
  min-height: 100vh;
  background: #F5F5F7;
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: #F5F5F7;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: #333;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.content {
  padding: 16px;
}

/* 紧急提醒横幅 */
.urgent-banner {
  background: #FEF2F2;
  border: 1px solid #FECACA;
  border-radius: 8px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.urgent-icon {
  font-size: 16px;
}

.urgent-text {
  font-size: 14px;
  color: #DC2626;
  font-weight: 500;
}

/* 提醒列表 */
.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.reminder-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  border-left: 4px solid #10B981;
}

.reminder-card.urgent {
  border-left-color: #F59E0B;
}

.reminder-card.overdue {
  border-left-color: #EF4444;
}

.reminder-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.reminder-type {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.reminder-status {
  font-size: 13px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 4px;
}

.reminder-status.normal {
  color: #10B981;
  background: #D1FAE5;
}

.reminder-status.urgent {
  color: #F59E0B;
  background: #FEF3C7;
}

.reminder-status.overdue {
  color: #EF4444;
  background: #FEE2E2;
}

.reminder-main {
  margin-bottom: 12px;
}

.reminder-dates {
  display: flex;
  align-items: center;
  gap: 12px;
}

.date-item {
  flex: 1;
}

.date-label {
  display: block;
  font-size: 12px;
  color: #999;
  margin-bottom: 4px;
}

.date-value {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.date-arrow {
  font-size: 16px;
  color: #ccc;
}

.reminder-interval {
  font-size: 12px;
  color: #666;
  margin-bottom: 8px;
}

.interval-text {
  color: #666;
}

.reminder-note {
  font-size: 12px;
  color: #999;
  padding-top: 8px;
  border-top: 1px solid #f0f0f0;
  margin-bottom: 8px;
}

.reminder-actions {
  display: flex;
  gap: 12px;
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
}

.done-btn {
  background: #10B981;
  color: #fff;
}

.delete-btn {
  background: #FEE2E2;
  color: #EF4444;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: #999;
  margin-bottom: 24px;
}

.empty-btn {
  background: #0066FF;
  color: #fff;
  padding: 10px 24px;
  border-radius: 8px;
  font-size: 15px;
}

/* 表单 */
.form-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
}

.form-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 20px;
  text-align: center;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-picker {
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 14px;
  color: #333;
}

.picker-arrow {
  font-size: 12px;
  color: #999;
}

.form-textarea {
  width: 100%;
  height: 80px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-btns {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 15px;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: #0066FF;
  color: #fff;
}
