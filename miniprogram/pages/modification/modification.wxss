/* ===== 深色模式 ===== */
.page.dark-mode { background: #121212 !important; }
.dark-mode .nav-bar { background: rgba(15, 15, 15, 0.97) !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.page {
  min-height: 100vh;
  background: var(--bg);
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: var(--text-primary);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}

.content {
  padding: 16px;
}

.stats-card {
  background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
  border-radius: 12px;
  padding: 20px;
  text-align: center;
  margin-bottom: 16px;
}

.stats-value {
  font-size: 28px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4px;
}

.stats-label {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 16px;
}

.category-list {
  display: inline-flex;
  gap: 8px;
  padding: 4px 0;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background: var(--bg-card);
  border-radius: 16px;
  font-size: 13px;
  color: var(--text-secondary);
}

.category-tag.active {
  background: #8B5CF6;
  color: #fff;
}

.category-icon {
  font-size: 14px;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.record-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 16px;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.record-category {
  display: flex;
  align-items: center;
  gap: 6px;
}

.record-amount {
  font-size: 16px;
  font-weight: 600;
  color: #8B5CF6;
}

.record-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.record-info {
  display: flex;
  gap: 12px;
  margin-bottom: 8px;
}

.info-item {
  font-size: 13px;
  color: var(--text-secondary);
}

.record-meta {
  display: flex;
  gap: 12px;
  margin-bottom: 8px;
}

.record-date {
  font-size: 13px;
  color: var(--text-secondary);
}

.record-source {
  font-size: 13px;
  color: var(--text-secondary);
}

.record-note {
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 8px;
  padding-bottom: 8px;
  border-bottom: 1rpx solid var(--border);
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-car {
  font-size: 12px;
  color: var(--text-muted);
}

.record-delete {
  font-size: 13px;
  color: #EF4444;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: var(--text-muted);
  margin-bottom: 24px;
}

.empty-btn {
  background: #8B5CF6;
  color: #fff;
  padding: 10px 24px;
  border-radius: 8px;
  font-size: 15px;
}

.form-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 20px;
}

.form-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20px;
  text-align: center;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 8px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-picker {
  height: 44px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 14px;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 12px;
  color: var(--text-muted);
}

.form-textarea {
  width: 100%;
  height: 80px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-tip {
  font-size: 12px;
  color: #8B5CF6;
  text-align: center;
  margin-bottom: 16px;
}

.form-btns {
  display: flex;
  gap: 12px;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 15px;
}

.btn-cancel {
  background: var(--bg-input);
  color: var(--text-secondary);
}

.btn-save {
  background: #8B5CF6;
  color: #fff;
}
