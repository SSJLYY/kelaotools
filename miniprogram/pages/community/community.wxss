/* ========================================
   音效库页 — 简约风格
   所有颜色通过 CSS 变量自动适配深色模式
   ======================================== */

/* 搜索栏 */
.search-bar {
  padding: 18rpx 28rpx var(--space-sm);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-full);
  padding: 18rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border);
}

.search-icon {
  font-size: 26rpx;
  margin-right: var(--space-sm);
  opacity: 0.4;
}

.search-placeholder {
  font-size: var(--font-sm);
  color: var(--text-placeholder);
}

/* 分类标签 */
.cat-scroll {
  margin-bottom: var(--space-xs);
}

.cat-list {
  display: flex;
  gap: var(--space-sm);
  padding: 4rpx 28rpx var(--space-md);
  white-space: nowrap;
}

.cat-tag {
  flex-shrink: 0;
  padding: 10rpx 26rpx;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  background: var(--bg-card);
  border-radius: var(--radius-full);
  border: 2rpx solid var(--border);
  transition: all 0.2s;
}

.cat-active {
  background: var(--primary);
  color: #FFFFFF;
  border-color: var(--primary);
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(47, 102, 246, 0.25);
}

/* 分享 Banner */
.share-banner {
  display: flex;
  align-items: center;
  margin: 0 28rpx var(--space-md);
  padding: 18rpx var(--space-lg);
  background: var(--primary-light);
  border-radius: var(--radius-md);
}

.share-icon {
  font-size: 28rpx;
  margin-right: var(--space-sm);
}

.share-text {
  flex: 1;
  font-size: var(--font-xs);
  color: var(--primary);
}

.share-btn {
  font-size: 20rpx !important;
  font-weight: 600;
  color: #FFFFFF !important;
  background: var(--primary) !important;
  border-radius: var(--radius-full) !important;
  padding: 8rpx 22rpx !important;
  line-height: 1.6 !important;
}

/* 音效卡片 */
.sound-list {
  padding: 0 28rpx;
}

.sound-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-md);
  padding: 22rpx;
  box-shadow: var(--shadow-sm);
}

.sound-main {
  display: flex;
  align-items: center;
}

.sound-play-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 14rpx rgba(47, 102, 246, 0.25);
}

.sound-play-btn.playing {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  box-shadow: 0 4rpx 14rpx rgba(255, 107, 107, 0.3);
}

.play-icon {
  font-size: 20rpx;
  color: #FFFFFF;
}

.sound-info {
  flex: 1;
  margin-left: 18rpx;
  overflow: hidden;
}

.sound-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sound-meta {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
  gap: var(--space-xs);
}

.sound-source,
.sound-duration {
  font-size: 20rpx;
  color: var(--text-muted);
}

.sound-dot {
  font-size: 20rpx;
  color: var(--text-muted);
  opacity: 0.4;
}

.sound-actions {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-shrink: 0;
}

.action-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fav-btn {
  background: #FFF5E6;
}
.dark-mode .fav-btn {
  background: #2A2A1A;
}

.fav-active {
  background: #FEF3C7;
}
.dark-mode .fav-active {
  background: #3A3A1A;
}

.action-icon {
  font-size: 22rpx;
  color: #F59E0B;
}

.copy-btn {
  background: var(--primary-light);
}
.copy-btn .action-icon {
  font-size: 20rpx;
  color: var(--primary);
}