/* 自定义音效 */
.search-bar { padding:16rpx 24rpx; }
.search-box { display:flex;align-items:center;background:#FFF;border-radius:40rpx;padding:18rpx 24rpx;box-shadow:var(--shadow-sm); }
.search-icon { font-size:28rpx;margin-right:10rpx; }
.search-placeholder { font-size:var(--font-sm);color:#C0C0C0; }

.cat-scroll { margin-bottom:4rpx; }
.cat-list { display:flex;gap:10rpx;padding:8rpx 24rpx 14rpx;white-space:nowrap; }
.cat-tag { flex-shrink:0;padding:10rpx 24rpx;font-size:var(--font-xs);color:var(--text-secondary);background:#FFF;border-radius:32rpx;border:2rpx solid var(--border-color); }
.cat-active { background:var(--primary);color:#FFF;border-color:var(--primary);font-weight:600; }

.share-banner { display:flex;align-items:center;margin:0 24rpx 12rpx;padding:18rpx 20rpx;background:linear-gradient(135deg,#E8F2FF,#EDE9FE);border-radius:var(--radius-md); }
.share-icon { font-size:32rpx;margin-right:10rpx; }
.share-text { flex:1;font-size:var(--font-xs);color:var(--primary); }
.share-btn { font-size:20rpx!important;font-weight:600;color:#FFF!important;background:var(--primary)!important;border-radius:24rpx!important;padding:6rpx 20rpx!important;height:auto!important;line-height:1.6!important; }

.sound-list { padding:0 24rpx; }
.sound-card { background:#FFF;border-radius:var(--radius-md);margin-bottom:12rpx;padding:20rpx;box-shadow:var(--shadow-sm); }
.sound-main { display:flex;align-items:center; }
.sound-play-btn { width:64rpx;height:64rpx;border-radius:50%;background:var(--primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0; }
.play-icon { font-size:22rpx;color:var(--primary); }
.sound-info { flex:1;margin-left:16rpx;overflow:hidden; }
.sound-title { font-size:var(--font-md);font-weight:600;color:var(--text-primary);display:block; }
.sound-source { font-size:20rpx;color:var(--text-light);display:block;margin-top:4rpx; }
.sound-actions { display:flex;align-items:center;gap:10rpx;flex-shrink:0; }
.sound-car-icon { font-size:28rpx; }
.sound-duration { font-size:20rpx;color:var(--text-light); }
.sound-fav-btn { font-size:20rpx;font-weight:600;color:#64748B;background:#F8FAFC;border:none;border-radius:20rpx;padding:4rpx 16rpx;height:auto;line-height:1.6; }
.sound-fav-active { color:#D97706;background:#FEF3C7; }
.sound-copy-btn { font-size:20rpx;font-weight:600;color:var(--primary);background:var(--primary-light);border:none;border-radius:20rpx;padding:4rpx 18rpx;height:auto;line-height:1.6; }

.empty { text-align:center;padding:120rpx 0; }
.empty-emoji { font-size:80rpx;display:block; }
.empty-text { font-size:var(--font-md);color:var(--text-light);margin-top:20rpx;display:block; }
