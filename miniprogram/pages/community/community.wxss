/* 自定义音效 */
.search-bar { padding:20rpx 28rpx 12rpx; }
.search-box {
  display:flex;align-items:center;background:#FFF;
  border-radius:44rpx;padding:20rpx 28rpx;
  box-shadow:0 2rpx 12rpx rgba(0,0,0,0.04);
  border:2rpx solid rgba(0,0,0,0.04);
}
.search-icon { font-size:26rpx;margin-right:12rpx;opacity:0.5; }
.search-placeholder { font-size:var(--font-sm);color:#B0B0B0; }

.cat-scroll { margin-bottom:8rpx; }
.cat-list { display:flex;gap:12rpx;padding:4rpx 28rpx 16rpx;white-space:nowrap; }
.cat-tag {
  flex-shrink:0;padding:12rpx 28rpx;font-size:var(--font-xs);
  color:var(--text-secondary);background:#FFF;
  border-radius:36rpx;border:2rpx solid var(--border-color);
  transition:all 0.2s ease;
}
.cat-active {
  background:var(--primary);color:#FFF;border-color:var(--primary);
  font-weight:600;box-shadow:0 4rpx 16rpx rgba(0,102,255,0.2);
}

.share-banner {
  display:flex;align-items:center;margin:0 28rpx 16rpx;
  padding:20rpx 24rpx;background:linear-gradient(135deg,#E8F2FF,#EDE9FE);
  border-radius:var(--radius-md);
}
.share-icon { font-size:30rpx;margin-right:12rpx; }
.share-text { flex:1;font-size:var(--font-xs);color:var(--primary); }
.share-btn {
  font-size:20rpx!important;font-weight:600;color:#FFF!important;
  background:var(--primary)!important;border-radius:28rpx!important;
  padding:8rpx 24rpx!important;height:auto!important;line-height:1.6!important;
}

/* 音效列表 */
.sound-list { padding:0 28rpx; }
.sound-card {
  background:#FFF;border-radius:20rpx;margin-bottom:16rpx;
  padding:24rpx;box-shadow:0 2rpx 16rpx rgba(0,0,0,0.04);
  border:2rpx solid rgba(0,0,0,0.03);
  transition:transform 0.15s ease;
}
.sound-main { display:flex;align-items:center; }

/* 播放按钮 - 更精致 */
.sound-play-btn {
  width:56rpx;height:56rpx;border-radius:50%;
  background:linear-gradient(135deg,var(--primary),#4A8AFF);
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  box-shadow:0 4rpx 16rpx rgba(0,102,255,0.25);
  transition:transform 0.15s ease;
}
.sound-play-btn.playing {
  background:linear-gradient(135deg,#FF6B6B,#FF8E8E);
  box-shadow:0 4rpx 16rpx rgba(255,107,107,0.3);
}
.play-icon { font-size:20rpx;color:#FFF; }

/* 信息区域 - 名称突出，次要信息淡化 */
.sound-info { flex:1;margin-left:20rpx;overflow:hidden; }
.sound-title {
  font-size:var(--font-md);font-weight:600;color:var(--text-primary);
  display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.sound-meta {
  display:flex;align-items:center;margin-top:6rpx;gap:8rpx;
}
.sound-source { font-size:20rpx;color:var(--text-light);opacity:0.7; }
.sound-dot { font-size:20rpx;color:var(--text-light);opacity:0.4; }
.sound-duration { font-size:20rpx;color:var(--text-light);opacity:0.7; }

/* 操作按钮 - 紧凑精致 */
.sound-actions { display:flex;align-items:center;gap:12rpx;flex-shrink:0; }
.action-btn {
  width:52rpx;height:52rpx;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.15s ease;
}
.fav-btn { background:#FFF5E6; }
.fav-btn .action-icon { font-size:24rpx;color:#F59E0B; }
.fav-active { background:#FEF3C7; }
.fav-active .action-icon { color:#D97706; }
.copy-btn { background:var(--primary-light); }
.copy-btn .action-icon { font-size:22rpx; }

/* 空状态 */
.empty { text-align:center;padding:120rpx 0; }
.empty-emoji { font-size:80rpx;display:block; }
.empty-text { font-size:var(--font-md);color:var(--text-light);margin-top:20rpx;display:block; }

/* ===== 深色模式 ===== */
.dark-mode .search-box {
  background: #1E1E1E !important;
  border-color: rgba(255,255,255,0.06) !important;
}

.dark-mode .search-icon {
  color: #A0A0A0 !important;
}

.dark-mode .search-placeholder {
  color: #666666 !important;
}

.dark-mode .cat-tag {
  background: #2A2A2A !important;
  color: #A0A0A0 !important;
  border-color: #444444 !important;
}

.dark-mode .cat-active {
  background: #0066FF !important;
  color: #FFFFFF !important;
  border-color: #0066FF !important;
  box-shadow: 0 4rpx 16rpx rgba(0,102,255,0.3) !important;
}

.dark-mode .share-banner {
  background: linear-gradient(135deg, #1a2a3a, #2a1a3a) !important;
}

.dark-mode .share-text {
  color: #4D94FF !important;
}

.dark-mode .sound-card {
  background: #1E1E1E !important;
  border-color: rgba(255,255,255,0.04) !important;
}

.dark-mode .sound-play-btn {
  background: linear-gradient(135deg, #0066FF, #4A8AFF) !important;
  box-shadow: 0 4rpx 16rpx rgba(0,102,255,0.3) !important;
}

.dark-mode .sound-play-btn.playing {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E) !important;
  box-shadow: 0 4rpx 16rpx rgba(255,107,107,0.3) !important;
}

.dark-mode .play-icon {
  color: #FFFFFF !important;
}

.dark-mode .sound-title {
  color: #E5E5E5 !important;
}

.dark-mode .sound-source {
  color: #888888 !important;
}

.dark-mode .sound-dot {
  color: #666666 !important;
}

.dark-mode .sound-duration {
  color: #888888 !important;
}

.dark-mode .fav-btn {
  background: #2A2A1A !important;
}

.dark-mode .fav-btn .action-icon {
  color: #F59E0B !important;
}

.dark-mode .fav-active {
  background: #3A3A1A !important;
}

.dark-mode .fav-active .action-icon {
  color: #F59E0B !important;
}

.dark-mode .copy-btn {
  background: #1a2a3a !important;
}

.dark-mode .copy-btn .action-icon {
  color: #4D94FF !important;
}

.dark-mode .empty-text {
  color: #A0A0A0 !important;
}
