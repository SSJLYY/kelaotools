/* ===== 深色模式 ===== */
.dark-mode .page { background: #121212 !important; }
.dark-mode .nav-bar { background: #1a1a1a !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
/* 个人信息 */
.nav-bar { position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.97);border-bottom:1rpx solid rgba(0,0,0,0.05); }
.nav-content { display:flex;align-items:center;padding:0 24rpx; }
.nav-back { width:80rpx; }
.nav-back-icon { font-size:48rpx;font-weight:300;color:var(--text-primary); }
.nav-title-text { flex:1;text-align:center;font-size:34rpx;font-weight:600; }

.avatar-card { display:flex;align-items:center;margin:20rpx 24rpx;padding:28rpx;background:linear-gradient(135deg,#0066FF,#5B3FFF);border-radius:var(--radius-lg); }
.avatar-img { width:100rpx;height:100rpx;border-radius:50%;border:3rpx solid rgba(255,255,255,0.4); }
.avatar-info { margin-left:22rpx;flex:1; }
.avatar-name { font-size:36rpx;font-weight:800;color:#FFF;display:block; }
.avatar-tag { font-size:20rpx;color:rgba(255,255,255,0.6);display:block;margin-top:4rpx; }
.avatar-date { font-size:20rpx;color:rgba(255,255,255,0.5);display:block;margin-top:4rpx; }

.section-title {
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin:24rpx 24rpx 12rpx;
  font-size:28rpx;
  font-weight:600;
  color:#333;
}

.edit-btn {
  font-size:26rpx;
  font-weight:400;
  color:#0066FF;
}

.info-card { margin:0 24rpx 20rpx;background:#FFF;border-radius:var(--radius-lg);padding:8rpx 0; }
.info-item { display:flex;align-items:center;justify-content:space-between;padding:22rpx 28rpx;border-bottom:1rpx solid #F5F5F5; }
.info-item:last-child { border-bottom:none; }
.info-left { display:flex;align-items:center;gap:12rpx; }
.info-icon { font-size:32rpx; }
.info-label { font-size:var(--font-md);color:var(--text-primary); }
.info-value { font-size:var(--font-sm);color:var(--text-light); }

/* 工具排序 */
.tool-sort-card { padding:4rpx 0; }
.tool-sort-item {
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:20rpx 28rpx;
  border-bottom:1rpx solid #F5F5F5;
}
.tool-sort-item:last-child { border-bottom:none; }
.tool-sort-left { display:flex;align-items:center;gap:16rpx;flex:1; }
.tool-icon { width:48rpx;height:48rpx; }
.tool-name { font-size:28rpx;color:#333; }
.tool-name.disabled { color:#CCC; }
.tool-toggle {
  width:40rpx;
  height:40rpx;
  border:2rpx solid #ddd;
  border-radius:8rpx;
  display:flex;
  align-items:center;
  justify-content:center;
}
.toggle-icon {
  font-size:24rpx;
  color:transparent;
}
.toggle-icon.active {
  color:#0066FF;
}
.tool-sort-btns { display:flex;gap:16rpx; }
.sort-btn {
  width:56rpx;
  height:56rpx;
  background:#F0F0F0;
  border-radius:8rpx;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:24rpx;
  color:#666;
}
.sort-btn:active { background:#E0E0E0; }

.action-area { padding:0 28rpx;display:flex;flex-direction:column;align-items:center;gap:20rpx; }
.sync-btn { width:100%;height:88rpx;background:var(--primary-light);border:none;border-radius:44rpx;font-size:var(--font-md);font-weight:600;color:var(--primary);display:flex;align-items:center;justify-content:center; }
.logout-btn { width:100%;height:88rpx;background:#FEE2E2;border:none;border-radius:44rpx;font-size:var(--font-md);font-weight:600;color:#EF4444;display:flex;align-items:center;justify-content:center; }
.clear-text { font-size:var(--font-xs);color:#CCC;padding:8rpx; }

/* ===== 深色模式补充 ===== */
.dark-mode .nav-title-text { color: #E5E5E5 !important; }
.dark-mode .nav-back-icon { color: #E5E5E5 !important; }
.dark-mode .avatar-card { background: linear-gradient(135deg, #004ACC, #4B2FFF) !important; }
.dark-mode .section-title { color: #E5E5E5 !important; }
.dark-mode .info-card { background: #1E1E1E !important; }
.dark-mode .info-item { border-bottom-color: #333333 !important; }
.dark-mode .info-label { color: #E5E5E5 !important; }
.dark-mode .info-value { color: #A0A0A0 !important; }
.dark-mode .tool-sort-card { background: #1E1E1E !important; }
.dark-mode .tool-sort-item { border-bottom-color: #333333 !important; }
.dark-mode .tool-name { color: #E5E5E5 !important; }
.dark-mode .tool-name.disabled { color: #666666 !important; }
.dark-mode .toggle-icon { border-color: #444444 !important; }
.dark-mode .toggle-icon.active { background: #0066FF !important; border-color: #0066FF !important; }
.dark-mode .sort-btn { background: #2A2A2A !important; color: #A0A0A0 !important; }
.dark-mode .sort-btn:active { background: #333333 !important; }
.dark-mode .sync-btn { background: #1a2a3a !important; color: #4D94FF !important; }
.dark-mode .logout-btn { background: #2a1a1a !important; color: #EF4444 !important; }
.dark-mode .clear-text { color: #666666 !important; }
.dark-mode .edit-btn { color: #4D94FF !important; }
