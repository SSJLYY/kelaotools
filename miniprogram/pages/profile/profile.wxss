/* 个人信息 */
.nav-bar { position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.97);border-bottom:1rpx solid rgba(0,0,0,0.05); }
.nav-content { display:flex;align-items:center;padding:0 24rpx; }
.nav-back { width:80rpx; }
.nav-back-icon { font-size:48rpx;font-weight:300;color:var(--text-primary); }
.nav-title-text { flex:1;text-align:center;font-size:34rpx;font-weight:600; }

.avatar-card { display:flex;align-items:center;margin:20rpx 24rpx;padding:28rpx;background:linear-gradient(135deg,#0066FF,#5B3FFF);border-radius:var(--radius-lg); }
.avatar-img { width:100rpx;height:100rpx;border-radius:50%;border:3rpx solid rgba(255,255,255,0.4); }
.avatar-info { margin-left:22rpx;flex:1; }
.avatar-name { font-size:36rpx;font-weight:800;color:#FFF;display:block; }
.avatar-tag { font-size:20rpx;color:rgba(255,255,255,0.6);display:block;margin-top:4rpx; }
.avatar-date { font-size:20rpx;color:rgba(255,255,255,0.5);display:block;margin-top:4rpx; }

.info-card { margin:0 24rpx 20rpx;background:#FFF;border-radius:var(--radius-lg);padding:8rpx 0; }
.info-item { display:flex;align-items:center;justify-content:space-between;padding:22rpx 28rpx;border-bottom:1rpx solid #F5F5F5; }
.info-item:last-child { border-bottom:none; }
.info-label { font-size:var(--font-md);color:var(--text-primary); }
.info-value { font-size:var(--font-sm);color:var(--text-light); }

.action-area { padding:0 28rpx;display:flex;flex-direction:column;align-items:center;gap:20rpx; }
.sync-btn { width:100%;height:88rpx;background:var(--primary-light);border:none;border-radius:44rpx;font-size:var(--font-md);font-weight:600;color:var(--primary);display:flex;align-items:center;justify-content:center; }
.logout-btn { width:100%;height:88rpx;background:#FEE2E2;border:none;border-radius:44rpx;font-size:var(--font-md);font-weight:600;color:#EF4444;display:flex;align-items:center;justify-content:center; }
.clear-text { font-size:var(--font-xs);color:#CCC;padding:8rpx; }
