/* ========================================
   首页 — 简约风格
   所有颜色通过 CSS 变量自动适配深色模式
   ======================================== */

/* ===== 骨架屏占位 ===== */
.nav-placeholder {
  width: 100%;
}

/* ===== 用户欢迎区 → 与车辆信息融合 ===== */
.welcome-section {
  padding: var(--space-lg);
  padding-top: 12rpx;
}

.welcome-row {
  display: flex;
  align-items: center;
}

.welcome-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid var(--primary);
  background: var(--primary-light);
  flex-shrink: 0;
}

.welcome-text {
  margin-left: 18rpx;
  flex: 1;
  overflow: hidden;
}

.welcome-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.welcome-sub {
  font-size: var(--font-sm);
  color: var(--text-muted);
  margin-top: 4rpx;
  display: block;
}

/* 车辆标签 */
.welcome-car-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 10rpx;
  padding: 6rpx 16rpx;
  background: var(--primary-light);
  border-radius: var(--radius-full);
}

.car-badge-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.car-badge-text {
  font-size: var(--font-xs);
  color: var(--primary);
  font-weight: 600;
}

/* ===== 公告通知栏 ===== */
.notice-bar {
  margin: 0 var(--space-lg) var(--space-md);
  background: #FFFBE6;
  border-radius: var(--radius-sm);
  padding: 0 var(--space-md);
  height: 64rpx;
  display: flex;
  align-items: center;
}
.dark-mode .notice-bar {
  background: #2A2A1A;
}
.notice-swiper {
  flex: 1;
  height: 64rpx;
}
.notice-item {
  display: flex;
  align-items: center;
  height: 64rpx;
}
.notice-tag {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  color: #fff;
  font-weight: 600;
}
.notice-tag-new {
  background: var(--orange);
}
.notice-tag-update {
  background: var(--primary);
}
.notice-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 车辆卡片 ===== */
.car-section {
  margin: 0 var(--space-lg) var(--space-md);
}

/* 未绑车 Banner */
.add-car-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--primary-gradient);
  border-radius: var(--radius-xl);
  padding: 32rpx 28rpx;
}
.add-car-left {
  flex: 1;
  overflow: hidden;
}
.add-car-title {
  font-size: var(--font-xl);
  font-weight: 800;
  color: #FFFFFF;
  display: block;
}
.add-car-sub {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-top: 8rpx;
}
.add-car-btn {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  padding: 12rpx 28rpx;
  margin-top: 20rpx;
  color: #FFFFFF;
  font-size: var(--font-sm);
  font-weight: 600;
}
.add-car-arrow {
  margin-left: 4rpx;
  font-size: 28rpx;
}
.add-car-right {
  margin-left: var(--space-lg);
  flex-shrink: 0;
  font-size: 100rpx;
  opacity: 0.85;
}

/* 已绑车卡片 */
.mycar-card {
  background: var(--primary-gradient);
  border-radius: var(--radius-xl);
  padding: 28rpx;
}
.mycar-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.mycar-model-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}
.mycar-emoji {
  font-size: 48rpx;
  flex-shrink: 0;
}
.mycar-text {
  margin-left: 16rpx;
  overflow: hidden;
}
.mycar-model {
  font-size: var(--font-lg);
  font-weight: 800;
  color: #FFFFFF;
}
.mycar-plate {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.55);
  margin-top: 4rpx;
  display: block;
}
.mycar-manage {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.6);
}
.mycar-manage-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-left: 2rpx;
}
.mycar-status {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}
.mycar-status-text {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.55);
}

/* ===== 快捷入口 2×2 ===== */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: var(--space-sm);
}

.quick-item {
  flex: 0 0 calc(50% - 6rpx);
  width: calc(50% - 6rpx);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx 20rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  box-sizing: border-box;
  position: relative;
}
.quick-item:active {
  background: var(--bg-card-hover);
}

.quick-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.quick-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-left: 16rpx;
  flex: 1;
}

.quick-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  padding: 2rpx 12rpx;
  background: var(--danger);
  color: #FFF;
  font-size: 18rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

/* ===== 提示条 ===== */
.tip-bar {
  display: flex;
  align-items: center;
  padding: 18rpx var(--space-lg);
  background: var(--primary-light);
  border-radius: var(--radius-lg);
}
.dark-mode .tip-bar {
  background: #1E2A4A;
}
.tip-bar-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.tip-bar-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--primary);
  line-height: 1.5;
}
.tip-bar-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-left: var(--space-sm);
}

/* ===== 用车小贴士 ===== */
.tips-banner {
  display: flex;
  align-items: center;
  padding: 18rpx var(--space-lg);
  background: #FFFBF0;
  border-radius: var(--radius-lg);
  border: 1rpx solid #FDE68A;
}
.dark-mode .tips-banner {
  background: #2A2A1A;
  border-color: #4A4A2A;
}
.tips-banner-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}
.tips-banner-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}
.tips-banner-text {
  margin-left: 14rpx;
  overflow: hidden;
}
.tips-banner-label {
  font-size: 20rpx;
  color: #92400E;
  display: block;
}
.dark-mode .tips-banner-label {
  color: var(--warning);
}
.tips-banner-title {
  font-size: var(--font-sm);
  font-weight: 700;
  color: #92400E;
  display: block;
}
.dark-mode .tips-banner-title {
  color: var(--warning);
}
.tips-banner-right {
  flex-shrink: 0;
  margin-left: var(--space-md);
}
.tips-banner-arrow {
  font-size: 32rpx;
  color: #CCC;
}

/* ===== 数据概览 ===== */
.data-overview {
  display: flex;
  align-items: center;
  margin: var(--space-xs) var(--space-lg) var(--space-md);
  padding: 24rpx 0;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.dark-mode .data-overview {
  background: var(--bg-card);
}

.data-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.data-value {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-primary);
}
.data-label {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: 4rpx;
}
.data-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--border);
}

/* ===== 工具列表 ===== */
.tool-list {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.tool-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx var(--space-lg);
  border-bottom: 1rpx solid var(--border-light);
}
.tool-item:last-child {
  border-bottom: none;
}
.tool-item:active {
  background: var(--bg-card-hover);
}

.tool-item-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.tool-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}

.tool-item-info {
  margin-left: 18rpx;
  flex: 1;
  overflow: hidden;
}

.tool-item-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.tool-item-desc {
  font-size: var(--font-xs);
  color: var(--text-muted);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-arrow {
  font-size: 32rpx;
  color: #CCC;
  font-weight: 300;
  margin-left: var(--space-sm);
}
.dark-mode .tool-arrow {
  color: #555;
}

.tool-count {
  text-align: center;
  padding: 14rpx 0;
}

.tool-count-text {
  font-size: var(--font-xs);
  color: var(--text-muted);
}

/* ===== 充电优惠券（横向滚动） ===== */
.coupon-scroll {
  width: 100%;
  white-space: nowrap;
}

.coupon-list {
  display: flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.coupon-card {
  flex-shrink: 0;
  width: 520rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  border-top: 5rpx solid var(--orange);
  white-space: normal;
  position: relative;
}
.coupon-card.coupon-bind {
  border-top-color: var(--primary);
}
.coupon-card.coupon-community {
  border-top-color: var(--success);
}

.coupon-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.coupon-amount-box {
  display: flex;
  align-items: baseline;
}

.coupon-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--orange);
}
.coupon-card.coupon-bind .coupon-symbol {
  color: var(--primary);
}
.coupon-card.coupon-community .coupon-symbol {
  color: var(--success);
}

.coupon-amount {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--orange);
  line-height: 1;
  margin-left: 2rpx;
}
.coupon-card.coupon-bind .coupon-amount {
  color: var(--primary);
}
.coupon-card.coupon-community .coupon-amount {
  color: var(--success);
}

.coupon-btn {
  font-size: var(--font-sm);
  font-weight: 600;
  padding: 8rpx 28rpx;
  border-radius: var(--radius-full);
  border: none;
  background: #FFF7ED;
  color: var(--orange);
  line-height: 1.5;
}
.coupon-btn-blue {
  background: var(--primary-light);
  color: var(--primary);
}
.coupon-btn-green {
  background: #ECFDF5;
  color: var(--success);
}
.dark-mode .coupon-btn {
  background: #2A2A2A;
  color: var(--text-primary);
}

.coupon-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.coupon-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  display: block;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.coupon-source {
  display: flex;
  align-items: center;
  font-size: var(--font-xs);
  color: var(--text-muted);
}

.coupon-notice {
  font-size: 20rpx;
  color: var(--danger);
  margin-top: 10rpx;
  padding: 8rpx 12rpx;
  background: #FEF2F2;
  border-radius: var(--radius-sm);
  line-height: 1.5;
}
.dark-mode .coupon-notice {
  background: #2A1A1A;
}

/* ===== 兼职外快推荐 ===== */
.sidejob-list {
  display: flex;
  gap: 12rpx;
}

.sidejob-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx 14rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sidejob-icon-box {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  margin-bottom: 14rpx;
}

.sidejob-name {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.sidejob-desc {
  font-size: var(--font-xs);
  color: var(--danger);
  margin-bottom: 14rpx;
}

.sidejob-btn {
  width: 100%;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
  background: var(--primary-light);
  border: none;
  border-radius: var(--radius-full);
  padding: 8rpx 0;
  line-height: 1.4;
}