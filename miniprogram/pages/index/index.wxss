/* ========================================
   氪佬工具箱 - 首页样式
   ======================================== */

.page {
  width: 100%;
  box-sizing: border-box;
  min-height: 100vh;
  background: var(--bg-page);
}

/* ===== 我的车辆卡片（已绑车） ===== */
.mycar-card {
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.15);
}
.mycar-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.mycar-model-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}
.mycar-emoji { font-size: 48rpx; flex-shrink: 0; }
.mycar-text { margin-left: 16rpx; overflow: hidden; }
.mycar-model {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
}
.mycar-plate {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  display: block;
  margin-top: 4rpx;
}
.mycar-manage {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.mycar-manage-text {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.6);
}
.mycar-manage-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-left: 2rpx;
}
.mycar-status {
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}
.mycar-status-text {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.55);
}

/* ===== 添加车辆 Banner ===== */
.banner-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.15);
}
.banner-card-has-car {
  background: linear-gradient(135deg, #0066FF, #5B3FFF);
  padding: 24rpx 28rpx;
}

.banner-left { flex: 1; overflow: hidden; }
.banner-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  letter-spacing: 1rpx;
}
.banner-sub {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.65);
  display: block;
  margin-top: 10rpx;
}
.banner-btn {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #0066FF, #5B3FFF);
  border-radius: 40rpx;
  padding: 14rpx 32rpx;
  margin-top: 24rpx;
}
.banner-btn-hover {
  opacity: 0.8;
}
.banner-btn-text {
  font-size: var(--font-sm);
  font-weight: 600;
  color: #FFFFFF;
}
.banner-btn-arrow {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 300;
  margin-left: 6rpx;
}
.banner-right { margin-left: 24rpx; flex-shrink: 0; }
.banner-car-icon { font-size: 120rpx; opacity: 0.85; }

/* ===== 欢迎区车辆标签 ===== */
.welcome-car-badge {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  padding: 10rpx 20rpx;
  background: var(--primary-light);
  border-radius: 40rpx;
  align-self: flex-start;
}
.car-badge-icon { font-size: 28rpx; margin-right: 8rpx; }
.car-badge-text {
  font-size: var(--font-xs);
  color: var(--primary);
  font-weight: 600;
}

/* ===== 添加入口气泡引导 ===== */
.desktop-guide-bubble {
  margin: 20rpx 24rpx 0;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #EFF6FF, #F8FAFC);
  border: 2rpx solid #DBEAFE;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 18rpx rgba(0, 102, 255, 0.08);
}
.desktop-guide-bubble:active { opacity: 0.82; }
.bubble-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  background: #DBEAFE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}
.bubble-text {
  flex: 1;
  margin-left: 18rpx;
  overflow: hidden;
}
.bubble-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #1E3A8A;
  line-height: 1.35;
}
.bubble-sub {
  display: block;
  font-size: 22rpx;
  color: #64748B;
  margin-top: 4rpx;
}
.bubble-arrow {
  font-size: 34rpx;
  color: #94A3B8;
  margin-left: 12rpx;
}

/* ===== 首页月度报告卡片 ===== */
.report-card-home {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #0066FF, #1E40AF);
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 20rpx rgba(0, 102, 255, 0.3);
}
.report-card-left { flex: 1; }
.report-card-period {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.6);
  display: block;
}
.report-card-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: #FFF;
  display: block;
  margin-top: 4rpx;
}
.report-card-right { text-align: right; }
.report-card-amount {
  font-size: 44rpx;
  font-weight: 900;
  color: #FFF;
  display: block;
}
.report-card-action {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
  display: block;
}

/* ===== 快捷入口 2x2 ===== */
.quick-grid {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.quick-item {
  flex: 0 0 calc(50% - 8rpx);
  width: calc(50% - 8rpx);
  margin-bottom: 16rpx;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  position: relative;
  box-sizing: border-box;
}
.quick-item:active { background: #FAFAFA; }
.quick-icon {
  width: 72rpx; height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.quick-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-left: 18rpx;
  flex: 1;
}
.quick-badge {
  position: absolute;
  top: 8rpx; right: 8rpx;
  padding: 2rpx 12rpx;
  background: #EF4444;
  color: #FFF;
  font-size: 18rpx;
  border-radius: 16rpx;
  font-weight: 500;
}
.quick-empty { opacity: 0.6; pointer-events: none; }

/* ===== 提示条 ===== */
.tip-bar {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  background: #E8F4FD;
  border-radius: var(--radius-lg);
}
.tip-bar-active { background: #ECFDF5; }
.tip-icon-text { font-size: 32rpx; margin-right: 14rpx; }
.tip-content {
  flex: 1;
  font-size: var(--font-sm);
  color: #1E40AF;
  line-height: 1.5;
}
.tip-bar-active .tip-content { color: #065F46; }
.tip-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

/* ===== 用车小贴士Banner ===== */
.tips-banner {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  background: #FFFBF0;
  border-radius: var(--radius-lg);
  border: 2rpx solid #FDE68A;
}
.tips-banner-left { display: flex; align-items: center; flex: 1; overflow: hidden; }
.tips-banner-icon { font-size: 44rpx; flex-shrink: 0; }
.tips-banner-text { margin-left: 14rpx; overflow: hidden; }
.tips-banner-label { font-size: 20rpx; color: #92400E; display: block; }
.tips-banner-title { font-size: var(--font-sm); font-weight: 700; color: #92400E; display: block; }
.tips-banner-right { display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0; margin-left: 16px; max-width: 50%; }
.tips-banner-desc { font-size: 20rpx; color: var(--text-secondary); text-align: right; line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }
.tips-banner-arrow { font-size: 28rpx; color: #CCC; font-weight: 300; margin-top: 4rpx; }

/* ===== 自定义导航栏 ===== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(245, 245, 247, 0.95);
  backdrop-filter: blur(20rpx);
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-brand {
  display: flex;
  align-items: center;
  width: 160rpx;
}

.nav-logo {
  width: 56rpx;
  height: 56rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.nav-right {
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.nav-lang {
  font-size: 36rpx;
  padding: 8rpx 12rpx;
}

/* ===== 用户欢迎区 ===== */
.welcome-section {
  padding: 24rpx 24rpx 16rpx;
}

.welcome-row {
  display: flex;
  align-items: center;
}

.welcome-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid var(--primary);
  background: var(--primary-light);
}

.welcome-text {
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
}

.welcome-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.welcome-sub {
  font-size: var(--font-sm);
  color: var(--text-light);
  margin-top: 4rpx;
}

/* ===== 数据概览卡片 ===== */
.data-overview {
  display: flex;
  align-items: center;
  margin: 8rpx 24rpx 16rpx;
  padding: 28rpx 0;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.data-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.data-value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.data-label {
  font-size: var(--font-xs);
  color: var(--text-light);
  margin-top: 6rpx;
}

.data-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--border-color);
}

/* ===== 通用区域样式 ===== */
.section {
  margin: 0 24rpx 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 16rpx;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: var(--font-sm);
  color: var(--text-light);
}

/* ===== 工具列表 ===== */
.tool-list {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.tool-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
  transition: background 0.2s;
}
.tool-item:last-child {
  border-bottom: none;
}
.tool-item:active {
  background: #FAFAFA;
}

.tool-item-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.tool-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tool-emoji {
  font-size: 40rpx;
}

.tool-item-info {
  margin-left: 20rpx;
  flex: 1;
  overflow: hidden;
}

.tool-item-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.tool-item-desc {
  font-size: var(--font-xs);
  color: var(--text-light);
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  font-weight: 300;
}

.tool-count {
  text-align: center;
  padding: 16rpx 0;
}

.tool-count-text {
  font-size: var(--font-xs);
  color: var(--text-light);
}

/* ===== 充电优惠券（横向滚动） ===== */
.coupon-scroll {
  width: 100%;
  white-space: nowrap;
}

.coupon-list {
  display: flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.coupon-card {
  flex-shrink: 0;
  width: 560rpx;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  border-top: 6rpx solid var(--coupon-orange);
  white-space: normal;
  position: relative;
}
.coupon-card.coupon-newbie { border-top-color: #FF6B35; }
.coupon-card.coupon-bind { border-top-color: #0066FF; }
.coupon-card.coupon-community { border-top-color: #10B981; }

.coupon-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.coupon-amount-box {
  display: flex;
  align-items: baseline;
}

.coupon-symbol {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B35;
}
.coupon-card.coupon-bind .coupon-symbol { color: #0066FF; }
.coupon-card.coupon-community .coupon-symbol { color: #10B981; }

.coupon-amount {
  font-size: 72rpx;
  font-weight: 900;
  color: #FF6B35;
  line-height: 1;
  margin-left: 4rpx;
}
.coupon-card.coupon-bind .coupon-amount { color: #0066FF; }
.coupon-card.coupon-community .coupon-amount { color: #10B981; }

.coupon-btn {
  font-size: var(--font-sm);
  font-weight: 600;
  padding: 10rpx 32rpx;
  border-radius: var(--radius-full, 9999rpx);
  height: auto;
  line-height: 1.4;
  border: none;
}
.coupon-btn-orange { background: #FFF7ED; color: #FF6B35; }
.coupon-btn-blue  { background: #E8F2FF; color: #0066FF; }
.coupon-btn-green { background: #ECFDF5; color: #10B981; }

.coupon-title {
  font-size: var(--font-md);
  font-weight: 700;
  display: block;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.coupon-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  display: block;
  line-height: 1.6;
  margin-bottom: 14rpx;
}

.coupon-source {
  display: flex;
  align-items: center;
  font-size: var(--font-xs);
  color: var(--text-light);
}

.source-name {
  color: var(--text-secondary);
}

.coupon-notice {
  font-size: 20rpx;
  color: #EF4444;
  margin-top: 12rpx;
  padding: 10rpx 14rpx;
  background: #FEF2F2;
  border-radius: var(--radius-sm);
  line-height: 1.5;
}

/* ===== 兼职外快推荐 ===== */
.sidejob-list {
  display: flex;
  gap: 16rpx;
}

.sidejob-item {
  flex: 1;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 24rpx 16rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sidejob-icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.sidejob-emoji {
  font-size: 44rpx;
}

.sidejob-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.sidejob-desc {
  font-size: var(--font-xs);
  color: #EF4444;
  margin-bottom: 16rpx;
}

.sidejob-btn {
  width: 100%;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
  background: var(--primary-light);
  border: none;
  border-radius: var(--radius-full, 9999rpx);
  padding: 10rpx 0;
  height: auto;
  line-height: 1.4;
}

/* ===== 公告通知栏 ===== */
.notice-bar {
  margin: 0 24rpx 16rpx;
  background: #FFFBE6;
  border-radius: 8rpx;
  padding: 0 16rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
}
.notice-swiper { flex: 1; height: 64rpx; }
.notice-item { display: flex; align-items: center; height: 64rpx; }
.notice-tag {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  color: #fff;
}
.notice-tag-new { background: #FF6B35; }
.notice-tag-update { background: #0066FF; }
.notice-text {
  font-size: 24rpx;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
