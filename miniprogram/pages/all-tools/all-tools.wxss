/* 全部工具 */
.nav-bar { position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.97);border-bottom:1rpx solid rgba(0,0,0,0.05); }
.nav-content { display:flex;align-items:center;padding:0 24rpx; }
.nav-back { width:80rpx; }
.nav-back-icon { font-size:48rpx;font-weight:300;color:var(--text-primary); }
.nav-title-text { flex:1;text-align:center;font-size:34rpx;font-weight:600; }
.tool-group { margin:16rpx 24rpx 8rpx; }
.group-title { font-size:var(--font-md);font-weight:700;color:var(--text-primary);display:block;margin-bottom:14rpx; }
.tool-grid { display:flex;flex-wrap:wrap;gap:14rpx; }
.tool-cell { width:calc(50% - 7rpx);background:#FFF;border-radius:var(--radius-lg);padding:24rpx 20rpx;box-shadow:var(--shadow-sm);box-sizing:border-box; }
.tool-cell:active { background:#FAFAFA; }
.tool-cell-icon { width:72rpx;height:72rpx;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:36rpx;margin-bottom:14rpx; }
.tool-cell-name { font-size:var(--font-md);font-weight:700;color:var(--text-primary);display:block; }
.tool-cell-desc { font-size:20rpx;color:var(--text-light);display:block;margin-top:4rpx; }
