/* ========================================
   全部工具 — 简约风格
   所有颜色通过 CSS 变量自动适配深色模式
   ======================================== */

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 248, 250, 0.97);
  border-bottom: 1rpx solid var(--border-light);
}
.dark-mode .nav-bar {
  background: rgba(15, 15, 15, 0.97);
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 var(--space-lg);
}

.nav-back {
  width: 80rpx;
}

.nav-back-icon {
  font-size: 48rpx;
  font-weight: 300;
  color: var(--text-primary);
}

.nav-title-text {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 工具分组 */
.tool-group {
  margin: var(--space-md) var(--space-lg) var(--space-xs);
}

.group-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tool-cell {
  width: calc(50% - 6rpx);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 22rpx 18rpx;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}
.tool-cell:active {
  background: var(--bg-card-hover);
}

.tool-cell-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.tool-cell-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.tool-cell-desc {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
}