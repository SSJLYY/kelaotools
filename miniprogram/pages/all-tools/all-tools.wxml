<!-- 全部工具 -->
<view class="page {{darkMode ? 'dark-mode' : ''}}">

  <!-- 导航 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack"><text class="nav-back-icon">‹</text></view>
      <view class="nav-title-text">全部工具</view>
      <view style="width:80rpx;"></view>
    </view>
  </view>
  <view style="height: {{navTotalHeight}}px;"></view>

  <view class="tool-group" wx:for="{{toolCategories}}" wx:key="name">
    <text class="group-title">{{item.name}}</text>
    <view class="tool-grid">
      <view class="tool-cell" wx:for="{{item.items}}" wx:key="id" wx:for-item="tool" bindtap="onNav" data-path="{{tool.path}}">
        <view class="tool-cell-icon" style="background:{{tool.iconBg || '#EDE9FE'}};">{{tool.iconEmoji || '⚡'}}</view>
        <text class="tool-cell-name">{{tool.name}}</text>
        <text class="tool-cell-desc" wx:if="{{tool.desc}}">{{tool.desc}}</text>
      </view>
    </view>
  </view>

  <view style="height:40rpx;"></view>
</view>