<view class="page {{darkMode ? 'dark-mode' : ''}}" style="padding-top: {{navTotalHeight}}px;">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="top: 0; height: {{navTotalHeight}}px;">
    <view class="nav-bar-inner" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
      <view class="nav-left" bindtap="onBack">
        <text class="nav-icon">←</text>
      </view>
      <view class="nav-title">充电桩收藏</view>
      <view class="nav-right" wx:if="{{mode === 'list'}}" bindtap="showAdd">
        <text class="nav-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 列表模式 -->
  <view wx:if="{{mode === 'list'}}" class="content">
    <!-- 品牌筛选 -->
    <scroll-view scroll-x class="brand-scroll">
      <view class="brand-list">
        <view
          wx:for="{{brands}}"
          wx:key="*this"
          class="brand-tag {{activeBrand === item || (!activeBrand && item === '全部') ? 'active' : ''}}"
          bindtap="onBrandTap"
          data-brand="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>

    <!-- 收藏列表 -->
    <view wx:if="{{filteredStations.length > 0}}" class="station-list">
      <view wx:for="{{filteredStations}}" wx:key="id" class="station-card">
        <view class="station-header">
          <view class="station-brand">{{item.brand}}</view>
          <view class="station-power" wx:if="{{item.powerSummary}}">⚡ {{item.powerSummary}}</view>
          <view class="station-delete" bindtap="onDelete" data-id="{{item.id}}">删除</view>
        </view>
        <view wx:if="{{item.name}}" class="station-name">{{item.name}}</view>
        <view class="station-info">
          <view wx:if="{{item.speed}}" class="info-item">
            <text class="info-icon">⚡</text>
            <text class="info-text">{{item.speed}}kW</text>
          </view>
          <view wx:if="{{item.price}}" class="info-item">
            <text class="info-icon">💰</text>
            <text class="info-text">¥{{item.price}}/kWh</text>
          </view>
        </view>
        <view wx:if="{{item.address}}" class="station-address" bindtap="onCopyAddress" data-address="{{item.address}}">
          <text class="address-icon">📍</text>
          <text class="address-text">{{item.address}}</text>
          <text class="copy-btn">复制</text>
        </view>
        <view wx:if="{{item.note}}" class="station-note">{{item.note}}</view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">⚡</text>
      <text class="empty-text">还没有收藏充电站</text>
      <view class="empty-btn" bindtap="showAdd">添加充电站</view>
    </view>
  </view>

  <!-- 添加模式 -->
  <view wx:if="{{mode === 'add'}}" class="content">
    <view class="form-card">
      <view class="form-title">添加充电站收藏</view>

      <view class="form-item">
        <text class="form-label">品牌 *</text>
        <picker mode="selector" range="{{brands}}" bindchange="onBrandChange">
          <view class="form-picker">
            <text>{{form.brand || '请选择品牌'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">站点名称</text>
        <input
          class="form-input"
          placeholder="如：XX充电站(人民广场店)"
          value="{{form.name}}"
          bindinput="onInput"
          data-field="name"
        />
      </view>

      <view class="form-item">
        <text class="form-label">充电速度 (kW)</text>
        <input
          class="form-input"
          type="digit"
          placeholder="如：120"
          value="{{form.speed}}"
          bindinput="onInput"
          data-field="speed"
        />
      </view>

      <view class="form-item">
        <text class="form-label">电价 (元/kWh)</text>
        <input
          class="form-input"
          type="digit"
          placeholder="如：1.2"
          value="{{form.price}}"
          bindinput="onInput"
          data-field="price"
        />
      </view>

      <view class="form-item">
        <text class="form-label">地址</text>
        <input
          class="form-input"
          placeholder="详细地址"
          value="{{form.address}}"
          bindinput="onInput"
          data-field="address"
        />
      </view>

      <view class="form-item">
        <text class="form-label">备注</text>
        <textarea
          class="form-textarea"
          placeholder="可选，如：停车免费、有卫生间等"
          value="{{form.note}}"
          bindinput="onInput"
          data-field="note"
          maxlength="100"
        />
      </view>

      <view class="form-btns">
        <view class="btn-cancel" bindtap="showList">取消</view>
        <view class="btn-save" bindtap="saveStation">收藏</view>
      </view>
    </view>
  </view>
</view>
