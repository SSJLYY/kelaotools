/* ===== 深色模式 ===== */
.dark-mode .page,
.dark-mode page { background: #121212 !important; }
.dark-mode .nav-bar { background: #1a1a1a !important; }
.dark-mode .nav-bar-inner { background: #1a1a1a !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.dark-mode .nav-icon { color: #E5E5E5 !important; }
.page {
  min-height: 100vh;
  background: #F5F5F7;
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: #F5F5F7;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: #333;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.content {
  padding: 16px;
}

.brand-scroll {
  white-space: nowrap;
  margin-bottom: 16px;
}

.brand-list {
  display: inline-flex;
  gap: 8px;
  padding: 4px 0;
}

.brand-tag {
  display: inline-block;
  padding: 6px 14px;
  background: #fff;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.brand-tag.active {
  background: #0066FF;
  color: #fff;
}

.station-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.station-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
}

.station-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.station-brand {
  font-size: 15px;
  font-weight: 600;
  color: #0066FF;
  background: #E6F0FF;
  padding: 2px 10px;
  border-radius: 4px;
}

.station-power {
  font-size: 13px;
  font-weight: 600;
  color: #F59E0B;
  background: #FEF3C7;
  padding: 2px 8px;
  border-radius: 4px;
}

.station-delete {
  font-size: 13px;
  color: #EF4444;
}

.station-name {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.station-info {
  display: flex;
  gap: 16px;
  margin-bottom: 8px;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 4px;
}

.info-icon {
  font-size: 14px;
}

.info-text {
  font-size: 14px;
  color: #333;
}

.station-address {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 0;
  border-top: 1px solid #f0f0f0;
}

.address-icon {
  font-size: 14px;
}

.address-text {
  flex: 1;
  font-size: 13px;
  color: #666;
}

.copy-btn {
  font-size: 12px;
  color: #0066FF;
  padding: 2px 8px;
  border: 1px solid #0066FF;
  border-radius: 4px;
}

.station-note {
  font-size: 12px;
  color: #999;
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #f0f0f0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: #999;
  margin-bottom: 24px;
}

.empty-btn {
  background: #0066FF;
  color: #fff;
  padding: 10px 24px;
  border-radius: 8px;
  font-size: 15px;
}

.form-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
}

.form-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 20px;
  text-align: center;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-picker {
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 14px;
  color: #333;
}

.picker-arrow {
  font-size: 12px;
  color: #999;
}

.form-textarea {
  width: 100%;
  height: 80px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-btns {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 15px;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: #0066FF;
  color: #fff;
}

