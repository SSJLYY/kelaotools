page {
  min-height: 100vh;
  background: #F5F5F7;
  color: #1A1A2E;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(245, 245, 247, 0.96);
  backdrop-filter: blur(20rpx);
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.nav-back,
.nav-spacer {
  width: 96rpx;
}

.nav-back {
  font-size: 56rpx;
  line-height: 1;
  color: #1A1A2E;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
}

.hero-card {
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #0F172A, #1D4ED8);
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 36rpx rgba(29, 78, 216, 0.22);
}

.hero-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.hero-text {
  margin-left: 24rpx;
}

.hero-title {
  display: block;
  color: #FFF;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.hero-sub {
  display: block;
  color: rgba(255,255,255,0.74);
  font-size: 24rpx;
  margin-top: 10rpx;
  line-height: 1.6;
}

.guide-section,
.tips-card {
  margin: 24rpx;
  padding: 28rpx;
  background: #FFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
}

.section-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
}

.section-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ECFDF5;
  color: #059669;
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 12rpx;
}

.section-badge.blue {
  background: #E8F2FF;
  color: #0066FF;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
}

.mock-screen {
  position: relative;
  min-height: 360rpx;
  border-radius: 24rpx;
  background: #F8FAFC;
  border: 2rpx solid #E5E7EB;
  overflow: hidden;
  padding: 24rpx;
}

.mock-top {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mock-title {
  font-size: 28rpx;
  font-weight: 700;
}

.mock-menu {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #FFF;
  border: 1rpx solid #E5E7EB;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #111827;
}

.mock-divider {
  width: 1rpx;
  height: 28rpx;
  background: #E5E7EB;
}

.mock-arrow {
  position: absolute;
  top: 96rpx;
  right: 30rpx;
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  background: #DBEAFE;
  color: #1D4ED8;
  font-size: 22rpx;
  font-weight: 700;
}

.mock-panel {
  margin-top: 42rpx;
  background: #FFF;
  border-radius: 20rpx;
  padding: 16rpx;
}

.mock-option {
  padding: 20rpx 22rpx;
  font-size: 26rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.mock-option:last-child {
  border-bottom: none;
}

.active-option {
  color: #0066FF;
  font-weight: 800;
  background: #F0F7FF;
  border-radius: 14rpx;
}

.step-list {
  margin-top: 24rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.6;
  margin-top: 16rpx;
}

.step-no {
  width: 40rpx;
  height: 40rpx;
  margin-right: 14rpx;
  border-radius: 50%;
  background: #111827;
  color: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.mini-program-card {
  border-radius: 24rpx;
  background: linear-gradient(180deg, #F8FAFC, #EEF2FF);
  padding: 28rpx;
}

.mini-header {
  color: #64748B;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.mini-grid {
  display: flex;
  gap: 22rpx;
  margin-bottom: 22rpx;
}

.mini-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  background: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  color: #64748B;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.mini-icon.selected {
  background: #0066FF;
  color: #FFF;
}

.mini-tip {
  font-size: 24rpx;
  color: #475569;
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.tips-text {
  display: block;
  color: #64748B;
  font-size: 25rpx;
  line-height: 1.6;
}

.copy-btn {
  margin-top: 22rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #111827;
  color: #FFF;
  font-size: 26rpx;
  font-weight: 700;
  border: none;
}

.safe-bottom {
  height: 40rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 深色模式 ===== */
.dark-mode page {
  background: #121212 !important;
}

.dark-mode .nav-bar {
  background: #1a1a1a !important;
}

.dark-mode .nav-title {
  color: #E5E5E5 !important;
}

.dark-mode .nav-back {
  color: #E5E5E5 !important;
}

.dark-mode .guide-card {
  background: #1E1E1E !important;
}

.dark-mode .guide-title {
  color: #E5E5E5 !important;
}

.dark-mode .guide-desc {
  color: #A0A0A0 !important;
}

.dark-mode .guide-step {
  color: #A0A0A0 !important;
}
