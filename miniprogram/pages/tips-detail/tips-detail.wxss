/* ===== 深色模式 ===== */
.page.dark-mode { background: #121212 !important; }
.dark-mode .nav-bar { background: #1a1a1a !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
/* 小贴士详情 */
.nav-bar { position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,0.97);border-bottom:1rpx solid rgba(0,0,0,0.05); }
.nav-content { display:flex;align-items:center;padding:0 24rpx; }
.nav-back { width:80rpx; }
.nav-back-icon { font-size:48rpx;font-weight:300;color:var(--text-primary); }
.nav-title-text { flex:1;text-align:center;font-size:34rpx;font-weight:600; }

.content-card { margin:16rpx 24rpx;background: var(--bg-card);border-radius:var(--radius-lg);padding:32rpx 28rpx;box-shadow:var(--shadow-sm); }
.card-header { text-align:center;margin-bottom:20rpx; }
.tip-icon-box { width:100rpx;height:100rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20rpx; }
.tip-icon { font-size:52rpx; }
.card-title { font-size:38rpx;font-weight:800;color:var(--text-primary);display:block; }
.card-tags { display:flex;justify-content:center;gap:10rpx;margin-top:16rpx; }
.card-tag { padding:4rpx 18rpx;font-size:20rpx;font-weight:500;color:var(--primary);background:var(--primary-light);border-radius:20rpx; }
.card-summary { font-size:var(--font-sm);color:var(--text-secondary);line-height:1.7;display:block;text-align:center; }
.card-divider { height:1rpx;background:var(--border-light);margin:24rpx 0; }
.card-content { white-space:pre-wrap; }
.content-line { font-size:var(--font-sm);color:var(--text-primary);line-height:2;display:block; }

.related-section { margin:24rpx;background: var(--bg-card);border-radius:var(--radius-lg);padding:24rpx 20rpx;box-shadow:var(--shadow-sm); }
.related-title { font-size:var(--font-md);font-weight:700;display:block;margin-bottom:16rpx; }
.related-item { display:flex;align-items:center;padding:16rpx 0;border-bottom:1rpx solid var(--border-light); }
.related-item:last-child { border-bottom:none; }
.related-emoji { font-size:32rpx;margin-right:14rpx; }
.related-text { flex:1;font-size:var(--font-md);color:var(--text-primary); }
.related-arrow { font-size:32rpx;color:#CCC; }

/* ===== 深色模式补充 ===== */
.dark-mode .nav-title-text { color: #E5E5E5 !important; }
.dark-mode .nav-back-icon { color: #E5E5E5 !important; }
.dark-mode .content-card { background: #1E1E1E !important; }
.dark-mode .card-title { color: #E5E5E5 !important; }
.dark-mode .card-summary { color: #A0A0A0 !important; }
.dark-mode .card-tag { background: #1a2a3a !important; color: #4D94FF !important; }
.dark-mode .card-divider { background: #333333 !important; }
.dark-mode .content-line { color: #E5E5E5 !important; }
.dark-mode .related-section { background: #1E1E1E !important; }
.dark-mode .related-title { color: #E5E5E5 !important; }
.dark-mode .related-item { border-bottom-color: #333333 !important; }
.dark-mode .related-text { color: #E5E5E5 !important; }
.dark-mode .related-arrow { color: #666666 !important; }
