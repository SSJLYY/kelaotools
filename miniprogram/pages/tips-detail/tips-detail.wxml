<!-- 小贴士详情 -->
<view class="page" style="background:#F5F5F7;min-height:100vh;">

  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content" style="height: {{navBarHeight}}px;">
      <view class="nav-back" bindtap="onBack"><text class="nav-back-icon">‹</text></view>
      <view class="nav-title-text">用车小贴士</view>
      <view style="width:80rpx;"></view>
    </view>
  </view>
  <view style="height: {{navTotalHeight}}px;"></view>

  <!-- 内容卡片 -->
  <view class="content-card">
    <view class="card-header">
      <view class="tip-icon-box" style="background:{{tip.iconBg||'#DBEAFE'}};">
        <text class="tip-icon">{{tip.icon||'💡'}}</text>
      </view>
      <text class="card-title">{{tip.title}}</text>
      <view class="card-tags">
        <text class="card-tag" wx:for="{{tip.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <text class="card-summary">{{tip.summary}}</text>

    <view class="card-divider"></view>

    <view class="card-content">
      <view wx:for="{{contentLines}}" wx:key="index" class="content-line"
        style="{{item.isPlainText && item.parts[0].text.startsWith('【')?'font-size:30rpx;font-weight:700;margin-top:24rpx;margin-bottom:12rpx;':''}}"
      >
        <block wx:if="{{item.isPlainText}}">{{item.parts[0].text}}</block>
        <block wx:else>
          <text wx:for="{{item.parts}}" wx:for-item="part" wx:key="index" style="{{part.bold?'font-weight:700;color:#0F172A;':''}}">{{part.text}}</text>
        </block>
      </view>
    </view>
  </view>

  <!-- 相关推荐 -->
  <view class="related-section" wx:if="{{relatedTips.length > 0}}">
    <text class="related-title">相关推荐</text>
    <view wx:for="{{relatedTips}}" wx:key="id" class="related-item" bindtap="onRelatedTap" data-id="{{item.id}}">
      <text class="related-emoji">{{item.icon}}</text>
      <text class="related-text">{{item.title}}</text>
      <text class="related-arrow">›</text>
    </view>
  </view>

  <view style="height:40rpx;"></view>
</view>
