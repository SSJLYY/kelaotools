/* ===== 深色模式 ===== */
.dark-mode .page { background: #121212 !important; }
.dark-mode .nav-bar { background: #1a1a1a !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.page {
  min-height: 100vh;
  background: #F5F5F7;
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: #F5F5F7;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: #333;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.content {
  padding: 16px;
}

/* 提示卡片 */
.tip-card {
  background: #EBF5FF;
  border-radius: 8px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.tip-icon {
  font-size: 14px;
}

.tip-text {
  font-size: 13px;
  color: #0066FF;
}

/* 区块卡片 */
.section-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.select-all {
  font-size: 14px;
  color: #0066FF;
}

/* 类型列表 */
.type-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.type-item {
  display: flex;
  align-items: center;
  padding: 12px;
  background: #F9FAFB;
  border-radius: 8px;
  border: 2px solid transparent;
}

.type-item.checked {
  background: #EBF5FF;
  border-color: #0066FF;
}

.type-checkbox {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  border: 2px solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.type-checkbox.checked {
  background: #0066FF;
  border-color: #0066FF;
}

.check-icon {
  font-size: 12px;
  color: #fff;
  font-weight: 700;
}

.type-icon {
  font-size: 18px;
  margin-right: 12px;
}

.type-name {
  flex: 1;
  font-size: 15px;
  color: #333;
}

.type-count {
  font-size: 13px;
  color: #999;
}

/* 单选按钮 */
.radio-group {
  margin-top: 12px;
}

.radio-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  background: #F9FAFB;
  border-radius: 8px;
  border: 2px solid transparent;
}

.radio-item.active {
  background: #EBF5FF;
  border-color: #0066FF;
}

.radio-label {
  font-size: 14px;
  color: #333;
  margin-left: 4px;
}

/* 导出按钮 */
.export-section {
  margin-top: 24px;
  padding-bottom: 40px;
}

.export-btn {
  width: 100%;
  height: 48px;
  background: #0066FF;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.export-btn::after {
  border: none;
}

.export-btn[disabled] {
  background: #ccc;
  color: #fff;
}
