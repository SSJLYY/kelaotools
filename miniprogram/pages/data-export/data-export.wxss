/* ===== 深色模式 ===== */
.page.dark-mode { background: #121212 !important; }
.dark-mode .nav-bar { background: rgba(15, 15, 15, 0.97) !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.dark-mode .nav-icon { color: #E5E5E5 !important; }
.dark-mode .tip-card { background: #1a2a3a !important; }
.dark-mode .tip-text { color: #4D94FF !important; }
.dark-mode .section-card { background: #1E1E1E !important; }
.dark-mode .section-title { color: #E5E5E5 !important; }
.dark-mode .select-all { color: #4D94FF !important; }
.dark-mode .type-item { background: #2A2A2A !important; }
.dark-mode .type-item.checked { background: #1a2a3a !important; border-color: #0066FF !important; }
.dark-mode .type-checkbox { border-color: #444444 !important; }
.dark-mode .type-checkbox.checked { background: #0066FF !important; border-color: #0066FF !important; }
.dark-mode .type-name { color: #E5E5E5 !important; }
.dark-mode .type-count { color: #A0A0A0 !important; }
.dark-mode .radio-item { background: #2A2A2A !important; }
.dark-mode .radio-item.active { background: #1a2a3a !important; border-color: #0066FF !important; }
.dark-mode .radio-label { color: #E5E5E5 !important; }
.dark-mode .export-btn[disabled] { background: #333333 !important; }
.page {
  min-height: 100vh;
  background: var(--bg);
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: var(--text-primary);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}

.content {
  padding: 16px;
}

/* 提示卡片 */
.tip-card {
  background: #EBF5FF;
  border-radius: 8px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}

.tip-icon {
  font-size: 14px;
}

.tip-text {
  font-size: 13px;
  color: var(--primary);
}

/* 区块卡片 */
.section-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.select-all {
  font-size: 14px;
  color: var(--primary);
}

/* 类型列表 */
.type-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.type-item {
  display: flex;
  align-items: center;
  padding: 12px;
  background: #F9FAFB;
  border-radius: 8px;
  border: 2px solid transparent;
}

.type-item.checked {
  background: #EBF5FF;
  border-color: var(--primary);
}

.type-checkbox {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  border: 2px solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
}

.type-checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.check-icon {
  font-size: 12px;
  color: #fff;
  font-weight: 700;
}

.type-icon {
  font-size: 18px;
  margin-right: 12px;
}

.type-name {
  flex: 1;
  font-size: 15px;
  color: var(--text-primary);
}

.type-count {
  font-size: 13px;
  color: var(--text-muted);
}

/* 单选按钮 */
.radio-group {
  margin-top: 12px;
}

.radio-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  background: #F9FAFB;
  border-radius: 8px;
  border: 2px solid transparent;
}

.radio-item.active {
  background: #EBF5FF;
  border-color: var(--primary);
}

.radio-label {
  font-size: 14px;
  color: var(--text-primary);
  margin-left: 4px;
}

/* 导出按钮 */
.export-section {
  margin-top: 24px;
  padding-bottom: 40px;
}

.export-btn {
  width: 100%;
  height: 48px;
  background: var(--primary);
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.export-btn::after {
  border: none;
}

.export-btn[disabled] {
  background: #ccc;
  color: #fff;
}
