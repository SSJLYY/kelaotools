<view class="page {{darkMode ? 'dark-mode' : ''}}" style="padding-top: {{navTotalHeight}}px;">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="top: 0; height: {{navTotalHeight}}px;">
    <view class="nav-bar-inner" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
      <view class="nav-left" bindtap="onBack">
        <text class="nav-icon">←</text>
      </view>
      <view class="nav-title">电价走势</view>
      <view style="width:44px;"></view>
    </view>
  </view>

  <view class="content">
    <!-- Tab切换 -->
    <view class="tab-bar">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-item {{activeTab === item.key ? 'active' : ''}}"
        bindtap="onTabChange"
        data-tab="{{item.key}}"
      >
        {{item.name}}
      </view>
    </view>

    <!-- 电价走势 -->
    <view wx:if="{{activeTab === 'electricity'}}">
      <!-- 当前电价概览 -->
      <view class="price-overview">
        <view class="price-card current">
          <text class="price-label">当前电价</text>
          <text class="price-value">¥{{currentPrice}}</text>
          <text class="price-unit">/kWh</text>
        </view>
        <view class="price-cards">
          <view class="price-card peak">
            <text class="price-label">峰电</text>
            <text class="price-value">¥{{peakPrice}}</text>
          </view>
          <view class="price-card valley">
            <text class="price-label">谷电</text>
            <text class="price-value">¥{{valleyPrice}}</text>
          </view>
        </view>
      </view>

      <!-- 时段说明 -->
      <view class="time-info">
        <view class="time-item peak">
          <text class="time-icon">🔴</text>
          <text class="time-label">峰电时段</text>
          <text class="time-value">{{peakHours}}</text>
        </view>
        <view class="time-item valley">
          <text class="time-icon">🟢</text>
          <text class="time-label">谷电时段</text>
          <text class="time-value">{{valleyHours}}</text>
        </view>
      </view>

      <!-- 24小时电价图 -->
      <view class="chart-section">
        <text class="section-title">24小时电价走势</text>
        <scroll-view scroll-x class="chart-scroll">
          <view class="chart-container">
            <view wx:for="{{hourlyPrices}}" wx:key="hour" class="chart-bar-wrap">
              <view class="chart-bar {{item.type}}" style="height: {{item.percent}}%;"></view>
              <text class="chart-price">¥{{item.price}}</text>
              <text class="chart-hour">{{item.hour}}</text>
            </view>
          </view>
        </scroll-view>
        <view class="chart-legend">
          <view class="legend-item">
            <view class="legend-dot valley"></view>
            <text>谷电</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot normal"></view>
            <text>平电</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot peak"></view>
            <text>峰电</text>
          </view>
        </view>
      </view>

      <!-- 充电建议 -->
      <view class="suggestion-card">
        <text class="suggestion-icon">💡</text>
        <view class="suggestion-content">
          <text class="suggestion-title">最佳充电时间</text>
          <text class="suggestion-text">建议在晚上23:00后开始充电，电价仅为峰电的29%</text>
        </view>
      </view>
    </view>

    <!-- 省电技巧 -->
    <view wx:if="{{activeTab === 'tips'}}">
      <view class="tips-list">
        <view wx:for="{{tips}}" wx:key="title" class="tip-card">
          <text class="tip-icon">{{item.icon}}</text>
          <view class="tip-content">
            <text class="tip-title">{{item.title}}</text>
            <text class="tip-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
