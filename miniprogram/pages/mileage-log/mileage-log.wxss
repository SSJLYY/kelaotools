/* ===== ж·±и‰ІжЁЎејЏ ===== */
.page.dark-mode { background: #121212 !important; color: #E5E5E5 !important; }
.dark-mode .nav-bar { background: rgba(15, 15, 15, 0.97) !important; }
.dark-mode .nav-title { color: #E5E5E5 !important; }
.dark-mode .nav-back { color: #E5E5E5 !important; }
.dark-mode .nav-icon { color: #E5E5E5 !important; }
.page {
  min-height: 100vh;
  background: var(--bg);
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--bg);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: var(--text-primary);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary);
}

.content {
  padding: 16px;
}

/* з»џи®ЎеЌЎз‰‡ */
.stats-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
}

.stats-row {
  display: flex;
  align-items: center;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: var(--primary);
}

.stats-label {
  display: block;
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 4px;
}

.stats-divider {
  width: 1px;
  height: 40px;
  background: #f0f0f0;
}

/* и®°еЅ•е€—иЎЁ */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.record-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 16px;
}

.record-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.record-type {
  font-size: 14px;
  font-weight: 600;
  color: var(--primary);
  background: #E6F0FF;
  padding: 2px 10px;
  border-radius: 4px;
}

.record-date {
  flex: 1;
  text-align: right;
  font-size: 13px;
  color: var(--text-muted);
}

.record-delete {
  font-size: 13px;
  color: #EF4444;
  margin-left: 12px;
}

.record-main {
  display: flex;
  align-items: baseline;
  gap: 20px;
  margin-bottom: 8px;
}

.record-mileage {
  display: flex;
  align-items: baseline;
}

.mileage-value {
  font-size: 28px;
  font-weight: 700;
  color: var(--text-primary);
}

.mileage-unit {
  font-size: 14px;
  color: var(--text-secondary);
  margin-left: 4px;
}

.record-consumption {
  display: flex;
  align-items: baseline;
}

.consumption-value {
  font-size: 18px;
  font-weight: 600;
  color: #10B981;
}

.consumption-unit {
  font-size: 12px;
  color: var(--text-muted);
  margin-left: 4px;
}

.record-route {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.route-text {
  color: var(--text-secondary);
}

.record-note {
  font-size: 12px;
  color: var(--text-muted);
  padding-top: 8px;
  border-top: 1rpx solid var(--border);
}

/* з©єзЉ¶жЂ?*/
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: var(--text-muted);
  margin-bottom: 24px;
}

.empty-btn {
  background: var(--primary);
  color: #fff;
  padding: 10px 24px;
  border-radius: 8px;
  font-size: 15px;
}

/* иЎЁеЌ• */
.form-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 20px;
}

.form-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20px;
  text-align: center;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: var(--text-primary);
  margin-bottom: 8px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-picker {
  height: 44px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 14px;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 12px;
  color: var(--text-muted);
}

.form-textarea {
  width: 100%;
  height: 80px;
  border: 1rpx solid var(--border);
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-btns {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 15px;
}

.btn-cancel {
  background: var(--bg-input);
  color: var(--text-secondary);
}

.btn-save {
  background: var(--primary);
  color: #fff;
}

/* иѕ…еЉ©й©ѕй©¶ж ‡з­ѕ */
.record-assist {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  padding: 6px 10px;
  background: #FFF7ED;
  border-radius: 6px;
}

.assist-label {
  font-size: 12px;
  color: #F59E0B;
  font-weight: 600;
}

.assist-value {
  font-size: 13px;
  color: var(--text-primary);
  font-weight: 600;
}

.assist-ratio {
  font-size: 12px;
  color: #F59E0B;
  background: #FEF3C7;
  padding: 1px 6px;
  border-radius: 4px;
}

/* иѕ…еЉ©й©ѕй©¶еЌ жЇ”жЏђз¤є */
.form-hint {
  font-size: 12px;
  color: #F59E0B;
  margin-top: 4px;
  display: block;
}

/* е№ґеє¦ж±‡жЂ»еЌЎз‰?*/
.year-card {
  background: var(--bg-card);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
}

.year-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.year-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.year-picker {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 12px;
  border: 1rpx solid var(--border);
  border-radius: 6px;
}

.year-picker-text {
  font-size: 14px;
  color: var(--primary);
  font-weight: 600;
}

.year-stats-row {
  display: flex;
  margin-bottom: 16px;
}

.year-stats-item {
  flex: 1;
  text-align: center;
}

.year-stats-value {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: var(--primary);
}

.year-assist-color {
  color: #F59E0B;
}

.year-stats-label {
  display: block;
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 4px;
}

.year-month-list {
  border-top: 1rpx solid var(--border);
  padding-top: 12px;
}

.year-month-item {
  display: flex;
  align-items: center;
  padding: 6px 0;
  gap: 8px;
}

.year-month-name {
  width: 32px;
  font-size: 13px;
  color: var(--text-secondary);
}

.year-month-bar-wrap {
  flex: 1;
  height: 8px;
  background: #f0f0f0;
  border-radius: 4px;
  overflow: hidden;
}

.year-month-bar {
  height: 100%;
  background: var(--primary);
  border-radius: 4px;
  min-width: 2px;
}

.year-month-value {
  width: 60px;
  text-align: right;
  font-size: 12px;
  color: var(--text-primary);
  font-weight: 600;
}

.year-month-assist {
  width: 56px;
  text-align: right;
  font-size: 11px;
  color: #F59E0B;
}

/* ж·±и‰ІжЁЎејЏиЎҐе…… */
.dark-mode .stats-card,
.dark-mode .year-card,
.dark-mode .record-card,
.dark-mode .form-card { background: #1E1E1E !important; }
.dark-mode .stats-value { color: #4D9EFF !important; }
.dark-mode .stats-label { color: #888 !important; }
.dark-mode .stats-divider { background: #333 !important; }
.dark-mode .record-type { background: #1A2A3A !important; color: #4D9EFF !important; }
.dark-mode .record-date { color: #888 !important; }
.dark-mode .mileage-value { color: #E5E5E5 !important; }
.dark-mode .mileage-unit { color: #888 !important; }
.dark-mode .consumption-value { color: #34D399 !important; }
.dark-mode .consumption-unit { color: #888 !important; }
.dark-mode .route-text { color: #aaa !important; }
.dark-mode .record-note { color: #888 !important; border-top-color: #333 !important; }
.dark-mode .record-assist { background: #2A2010 !important; }
.dark-mode .assist-value { color: #E5E5E5 !important; }
.dark-mode .year-title { color: #E5E5E5 !important; }
.dark-mode .year-picker { border-color: #444 !important; }
.dark-mode .year-stats-value { color: #4D9EFF !important; }
.dark-mode .year-assist-color { color: #FBBF24 !important; }
.dark-mode .year-stats-label { color: #888 !important; }
.dark-mode .year-month-list { border-top-color: #333 !important; }
.dark-mode .year-month-name { color: #aaa !important; }
.dark-mode .year-month-bar-wrap { background: #333 !important; }
.dark-mode .year-month-value { color: #E5E5E5 !important; }
.dark-mode .form-label { color: #E5E5E5 !important; }
.dark-mode .form-input { background: var(--bg-input); border-color: #444 !important; color: #E5E5E5 !important; }
.dark-mode .form-picker { background: var(--bg-input); border-color: #444 !important; color: #E5E5E5 !important; }
.dark-mode .form-textarea { background: var(--bg-input); border-color: #444 !important; color: #E5E5E5 !important; }
.dark-mode .form-hint { color: #FBBF24 !important; }
.dark-mode .assist-label { color: #FBBF24 !important; }
.dark-mode .assist-ratio { background: #3A2A00 !important; color: #FBBF24 !important; }
.dark-mode .empty-state { background: transparent !important; }
.dark-mode .empty-text { color: #A0A0A0 !important; }
.dark-mode .empty-btn { background: #0066FF !important; color: #FFFFFF !important; }
.dark-mode .form-title { color: #E5E5E5 !important; }
.dark-mode .btn-cancel { background: #2A2A2A !important; color: #A0A0A0 !important; }
.dark-mode .btn-save { background: #0066FF !important; color: #FFFFFF !important; }
.dark-mode .picker-arrow { color: #A0A0A0 !important; }
.dark-mode .record-delete { color: #EF4444 !important; }
