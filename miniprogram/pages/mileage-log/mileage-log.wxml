<view class="page" style="padding-top: {{navTotalHeight}}px;">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="top: 0; height: {{navTotalHeight}}px;">
    <view class="nav-bar-inner" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
      <view class="nav-left" bindtap="onBack">
        <text class="nav-icon">←</text>
      </view>
      <view class="nav-title">里程记录</view>
      <view class="nav-right" wx:if="{{mode === 'list'}}" bindtap="showAdd">
        <text class="nav-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 列表模式 -->
  <view wx:if="{{mode === 'list'}}" class="content">
    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-value">{{totalMileage}}</text>
          <text class="stats-label">总里程(km)</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value">{{monthMileage}}</text>
          <text class="stats-label">本月(km)</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value">{{avgConsumption}}</text>
          <text class="stats-label">平均能耗</text>
        </view>
      </view>
    </view>

    <!-- 记录列表 -->
    <view wx:if="{{records.length > 0}}" class="record-list">
      <view wx:for="{{records}}" wx:key="id" class="record-card">
        <view class="record-header">
          <view class="record-type">{{item.type}}</view>
          <view class="record-date">{{item.date}}</view>
          <view class="record-delete" bindtap="onDelete" data-id="{{item.id}}">删除</view>
        </view>
        <view class="record-main">
          <view class="record-mileage">
            <text class="mileage-value">{{item.mileage}}</text>
            <text class="mileage-unit">km</text>
          </view>
          <view class="record-consumption" wx:if="{{item.consumption > 0}}">
            <text class="consumption-value">{{item.consumptionPer100}}</text>
            <text class="consumption-unit">kWh/100km</text>
          </view>
        </view>
        <view class="record-route" wx:if="{{item.startLocation || item.endLocation}}">
          <text class="route-text">{{item.startLocation || '起点'}} → {{item.endLocation || '终点'}}</text>
        </view>
        <view wx:if="{{item.note}}" class="record-note">{{item.note}}</view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">🛣️</text>
      <text class="empty-text">还没有里程记录</text>
      <view class="empty-btn" bindtap="showAdd">记录第一次出行</view>
    </view>
  </view>

  <!-- 添加模式 -->
  <view wx:if="{{mode === 'add'}}" class="content">
    <view class="form-card">
      <view class="form-title">添加里程记录</view>

      <view class="form-item">
        <text class="form-label">出行类型 *</text>
        <picker mode="selector" range="{{tripTypes}}" bindchange="onTypeChange">
          <view class="form-picker">
            <text>{{form.type || '请选择出行类型'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{form.date}}" bindchange="onDateChange">
          <view class="form-picker">
            <text>{{form.date}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">行驶里程 (km) *</text>
        <input
          class="form-input"
          type="digit"
          placeholder="如：50.5"
          value="{{form.mileage}}"
          bindinput="onInput"
          data-field="mileage"
        />
      </view>

      <view class="form-item">
        <text class="form-label">能耗 (kWh)</text>
        <input
          class="form-input"
          type="digit"
          placeholder="如：12.5，可选填"
          value="{{form.consumption}}"
          bindinput="onInput"
          data-field="consumption"
        />
      </view>

      <view class="form-item">
        <text class="form-label">起点</text>
        <input
          class="form-input"
          placeholder="如：家"
          value="{{form.startLocation}}"
          bindinput="onInput"
          data-field="startLocation"
        />
      </view>

      <view class="form-item">
        <text class="form-label">终点</text>
        <input
          class="form-input"
          placeholder="如：公司"
          value="{{form.endLocation}}"
          bindinput="onInput"
          data-field="endLocation"
        />
      </view>

      <view class="form-item">
        <text class="form-label">备注</text>
        <textarea
          class="form-textarea"
          placeholder="可选，如：堵车严重"
          value="{{form.note}}"
          bindinput="onInput"
          data-field="note"
          maxlength="100"
        />
      </view>

      <view class="form-btns">
        <view class="btn-cancel" bindtap="showList">取消</view>
        <view class="btn-save" bindtap="saveRecord">保存</view>
      </view>
    </view>
  </view>
</view>
