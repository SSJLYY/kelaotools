<view class="page" style="padding-top: {{navTotalHeight}}px;">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="top: 0; height: {{navTotalHeight}}px;">
    <view class="nav-bar-inner" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
      <view class="nav-left" bindtap="onBack">
        <text class="nav-icon">←</text>
      </view>
      <view class="nav-title">车主社区</view>
      <view class="nav-right" wx:if="{{mode === 'list'}}" bindtap="showAdd">
        <text class="nav-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 列表模式 -->
  <view wx:if="{{mode === 'list'}}" class="content">
    <!-- 分类筛选 -->
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view
          wx:for="{{categories}}"
          wx:key="key"
          class="category-tag {{activeCategory === item.key ? 'active' : ''}}"
          bindtap="onCategoryTap"
          data-category="{{item.key}}"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 帖子列表 -->
    <view wx:if="{{filteredPosts.length > 0}}" class="post-list">
      <view wx:for="{{filteredPosts}}" wx:key="id" class="post-card" bindtap="onPostTap" data-id="{{item.id}}">
        <view class="post-header">
          <view class="post-category">
            <text class="post-cat-icon">{{item.categoryIcon}}</text>
            <text class="post-cat-name">{{item.categoryName}}</text>
          </view>
          <text class="post-time">{{item.dateText}} {{item.timeText}}</text>
        </view>
        <text class="post-title">{{item.title}}</text>
        <text class="post-content">{{item.content}}</text>
        <view class="post-footer">
          <text class="post-user">{{item.userName}}</text>
          <view class="post-actions">
            <view class="action-item {{item.liked ? 'liked' : ''}}" bindtap="onLike" data-id="{{item.id}}">
              <text class="action-icon">{{item.liked ? '❤️' : '🤍'}}</text>
              <text class="action-count">{{item.likes}}</text>
            </view>
            <view class="action-item">
              <text class="action-icon">💬</text>
              <text class="action-count">{{item.comments}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有帖子</text>
      <view class="empty-btn" bindtap="showAdd">发第一帖</view>
    </view>
  </view>

  <!-- 详情模式 -->
  <view wx:if="{{mode === 'detail' && currentPost}}" class="content">
    <view class="detail-card">
      <view class="detail-header">
        <view class="post-category">
          <text class="post-cat-icon">{{currentPost.categoryIcon}}</text>
          <text class="post-cat-name">{{currentPost.categoryName}}</text>
        </view>
        <text class="detail-time">{{currentPost.dateText}} {{currentPost.timeText}}</text>
      </view>
      <text class="detail-title">{{currentPost.title}}</text>
      <text class="detail-content">{{currentPost.content}}</text>
      <view class="detail-footer">
        <text class="detail-user">{{currentPost.userName}}</text>
        <view class="detail-actions">
          <view class="action-item {{currentPost.liked ? 'liked' : ''}}" bindtap="onLike" data-id="{{currentPost.id}}">
            <text class="action-icon">{{currentPost.liked ? '❤️' : '🤍'}}</text>
            <text class="action-count">{{currentPost.likes}}</text>
          </view>
          <view class="action-item" bindtap="onDelete" data-id="{{currentPost.id}}">
            <text class="action-icon">🗑️</text>
            <text class="action-count">删除</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 评论区（预留） -->
    <view class="comment-section">
      <text class="comment-title">评论区（开发中）</text>
      <text class="comment-empty">暂无评论，快来发表第一条评论吧</text>
    </view>
  </view>

  <!-- 添加模式 -->
  <view wx:if="{{mode === 'add'}}" class="content">
    <view class="form-card">
      <view class="form-title">发帖</view>

      <view class="form-item">
        <text class="form-label">帖子分类 *</text>
        <picker mode="selector" range="{{categories}}" range-key="name" bindchange="onCategoryChange">
          <view class="form-picker">
            <text>{{categoryIndex >= 0 ? categories[categoryIndex].name : '请选择分类'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">标题 *</text>
        <input
          class="form-input"
          placeholder="请输入标题"
          value="{{form.title}}"
          bindinput="onInput"
          data-field="title"
          maxlength="50"
        />
      </view>

      <view class="form-item">
        <text class="form-label">内容 *</text>
        <textarea
          class="form-textarea"
          placeholder="分享你的用车心得..."
          value="{{form.content}}"
          bindinput="onInput"
          data-field="content"
          maxlength="500"
        />
      </view>

      <view class="form-btns">
        <view class="btn-cancel" bindtap="showList">取消</view>
        <view class="btn-save" bindtap="savePost">发布</view>
      </view>
    </view>
  </view>
</view>
