.page {
  min-height: 100vh;
  background: #F5F5F7;
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: #F5F5F7;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: #333;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.content {
  padding: 16px;
}

/* 分类筛选 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 16px;
}

.category-list {
  display: inline-flex;
  gap: 8px;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 14px;
  background: #fff;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.category-tag.active {
  background: #0066FF;
  color: #fff;
}

.category-icon {
  font-size: 14px;
}

/* 帖子列表 */
.post-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.post-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
}

.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.post-category {
  display: flex;
  align-items: center;
  gap: 4px;
}

.post-cat-icon {
  font-size: 12px;
}

.post-cat-name {
  font-size: 12px;
  color: #0066FF;
  background: #E6F0FF;
  padding: 2px 8px;
  border-radius: 4px;
}

.post-time {
  font-size: 12px;
  color: #999;
}

.post-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.post-content {
  display: block;
  font-size: 14px;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid #f0f0f0;
}

.post-user {
  font-size: 13px;
  color: #666;
}

.post-actions {
  display: flex;
  gap: 16px;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 4px;
}

.action-item.liked .action-icon {
  color: #EF4444;
}

.action-icon {
  font-size: 14px;
}

.action-count {
  font-size: 12px;
  color: #999;
}

/* 详情页 */
.detail-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.detail-time {
  font-size: 12px;
  color: #999;
}

.detail-title {
  display: block;
  font-size: 20px;
  font-weight: 700;
  color: #333;
  margin-bottom: 16px;
}

.detail-content {
  display: block;
  font-size: 15px;
  color: #333;
  line-height: 1.8;
  margin-bottom: 16px;
}

.detail-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16px;
  border-top: 1px solid #f0f0f0;
}

.detail-user {
  font-size: 14px;
  color: #666;
}

.detail-actions {
  display: flex;
  gap: 20px;
}

/* 评论区 */
.comment-section {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
}

.comment-title {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
}

.comment-empty {
  display: block;
  text-align: center;
  font-size: 14px;
  color: #999;
  padding: 40px 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: #999;
  margin-bottom: 24px;
}

.empty-btn {
  background: #0066FF;
  color: #fff;
  padding: 10px 24px;
  border-radius: 8px;
  font-size: 15px;
}

/* 表单 */
.form-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
}

.form-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 20px;
  text-align: center;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-picker {
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 14px;
  color: #333;
}

.picker-arrow {
  font-size: 12px;
  color: #999;
}

.form-textarea {
  width: 100%;
  height: 150px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-btns {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 15px;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: #0066FF;
  color: #fff;
}
