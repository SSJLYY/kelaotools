.page {
  min-height: 100vh;
  background: #F5F5F7;
}

.nav-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  background: #F5F5F7;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  padding: 0 16px;
}

.nav-left, .nav-right {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 20px;
  color: #333;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.content {
  padding: 16px;
}

/* 筛选标签 */
.filter-scroll {
  white-space: nowrap;
  margin-bottom: 16px;
}

.filter-list {
  display: inline-flex;
  gap: 8px;
}

.filter-tag {
  display: inline-block;
  padding: 6px 14px;
  background: #fff;
  border-radius: 16px;
  font-size: 13px;
  color: #666;
}

.filter-tag.active {
  background: #0066FF;
  color: #fff;
}

/* 评价列表 */
.review-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.review-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.review-station {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.review-rating {
  display: flex;
  align-items: center;
  gap: 4px;
}

.rating-star {
  font-size: 14px;
}

.rating-value {
  font-size: 16px;
  font-weight: 700;
  color: #F59E0B;
}

.review-ratings {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 12px;
}

.rating-item {
  display: flex;
  align-items: center;
  gap: 8px;
}

.rating-label {
  font-size: 13px;
  color: #666;
}

.rating-stars {
  display: flex;
  gap: 2px;
}

.star {
  font-size: 14px;
  color: #D1D5DB;
}

.star.filled {
  color: #F59E0B;
}

.review-comment {
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0f0f0;
}

.review-footer {
  display: flex;
  align-items: center;
  gap: 12px;
}

.review-user {
  font-size: 13px;
  color: #666;
}

.review-date {
  flex: 1;
  font-size: 12px;
  color: #999;
}

.review-delete {
  font-size: 13px;
  color: #EF4444;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: #999;
  margin-bottom: 24px;
}

.empty-btn {
  background: #0066FF;
  color: #fff;
  padding: 10px 24px;
  border-radius: 8px;
  font-size: 15px;
}

/* 表单 */
.form-card {
  background: #fff;
  border-radius: 12px;
  padding: 20px;
}

.form-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 20px;
  text-align: center;
}

.form-item {
  margin-bottom: 20px;
}

.form-label {
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
  display: block;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.rating-selector {
  display: flex;
  align-items: center;
  gap: 12px;
}

.rating-slider {
  flex: 1;
  margin: 0;
}

.rating-text {
  font-size: 14px;
  font-weight: 600;
  color: #F59E0B;
  min-width: 40px;
}

.form-textarea {
  width: 100%;
  height: 100px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-btns {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 15px;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-save {
  background: #0066FF;
  color: #fff;
}
