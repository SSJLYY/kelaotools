/* ========================================
   骨架屏 — 与简约设计系统对齐
   ======================================== */

.skeleton {
  width: 100%;
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.sk-animate {
  background: linear-gradient(90deg, #E8EBF0 25%, #F0F2F5 37%, #E8EBF0 63%);
  background-size: 200% 100%;
  animation: sk-shimmer 1.4s ease infinite;
}

@keyframes sk-shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

/* 导航栏 */
.sk-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 88rpx 24rpx 20rpx;
}
.sk-nav-logo { width: 56rpx; height: 56rpx; border-radius: 12rpx; }
.sk-nav-title { width: 200rpx; height: 36rpx; border-radius: 8rpx; }
.sk-nav-icon { width: 48rpx; height: 48rpx; border-radius: 50%; }

/* 公告栏 */
.sk-notice {
  margin: 16rpx 24rpx 0;
  height: 64rpx;
  border-radius: 8rpx;
}

/* 欢迎区 */
.sk-welcome {
  display: flex;
  align-items: center;
  padding: 24rpx;
}
.sk-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0; }
.sk-welcome-text { margin-left: 18rpx; flex: 1; }
.sk-line { border-radius: 6rpx; }
.sk-line-name { width: 180rpx; height: 32rpx; }
.sk-line-sub { width: 260rpx; height: 24rpx; margin-top: 10rpx; }

/* 车辆 Banner */
.sk-car-banner {
  margin: 0 24rpx 16rpx;
  height: 140rpx;
  border-radius: 20rpx;
}

/* 快捷入口 */
.sk-quick-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin: 16rpx 24rpx 0;
  gap: 12rpx;
}
.sk-quick-item {
  flex: 0 0 calc(50% - 6rpx);
  width: calc(50% - 6rpx);
  height: 100rpx;
  border-radius: 16rpx;
}

/* 提示条 */
.sk-tip-bar {
  margin: 16rpx 24rpx;
  height: 64rpx;
  border-radius: 16rpx;
}

/* 小贴士 */
.sk-tips-banner {
  margin: 0 24rpx 16rpx;
  height: 88rpx;
  border-radius: 16rpx;
}

/* 数据概览 */
.sk-data-overview {
  display: flex;
  align-items: center;
  margin: 8rpx 24rpx 16rpx;
  padding: 24rpx 0;
  background: var(--bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
}
.sk-data-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.sk-data-value { width: 120rpx; height: 38rpx; border-radius: 8rpx; }
.sk-data-label { width: 80rpx; height: 22rpx; border-radius: 6rpx; margin-top: 8rpx; }
.sk-data-divider { width: 1rpx; height: 40rpx; background: var(--border); }

/* Section Header */
.sk-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 16rpx;
}
.sk-line-title { width: 140rpx; height: 32rpx; }
.sk-line-more { width: 80rpx; height: 24rpx; }

/* 工具列表 */
.sk-tool-list {
  margin: 0 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.sk-tool-item {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}
.sk-tool-item:last-child { border-bottom: none; }
.sk-tool-icon { width: 72rpx; height: 72rpx; border-radius: 12rpx; flex-shrink: 0; }
.sk-tool-text { flex: 1; height: 28rpx; border-radius: 6rpx; margin-left: 18rpx; }
.sk-tool-arrow { width: 32rpx; height: 28rpx; border-radius: 6rpx; }

/* 优惠券 */
.sk-coupon-list {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  overflow: hidden;
}
.sk-coupon-card { flex-shrink: 0; width: 520rpx; height: 220rpx; border-radius: 16rpx; }

/* 兼职外快 */
.sk-sidejob-list { display: flex; gap: 12rpx; padding: 0 24rpx; }
.sk-sidejob-item { flex: 1; height: 200rpx; border-radius: 16rpx; }

/* ===== 深色模式 ===== */
.skeleton-dark {
  background: var(--bg);
}
.skeleton-dark .sk-data-overview {
  background: var(--bg-card);
  box-shadow: none;
}
.skeleton-dark .sk-data-divider {
  background: var(--border);
}
.skeleton-dark .sk-tool-list {
  background: var(--bg-card);
  box-shadow: none;
}
.skeleton-dark .sk-tool-item {
  border-bottom-color: var(--border-light);
}