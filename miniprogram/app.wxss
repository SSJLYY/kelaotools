/* ========================================
   氪佬工具箱 — 简约设计系统 v2
   使用 CSS 变量统一管理浅色/深色主题
   ======================================== */

/* ===== 浅色主题（默认） ===== */
page {
  /* 主色 */
  --primary: #2F66F6;
  --primary-light: #EBF2FF;
  --primary-gradient: linear-gradient(135deg, #2F66F6, #6366F1);

  /* 背景 & 卡片 */
  --bg: #F7F8FA;
  --bg-card: #FFFFFF;
  --bg-card-hover: #F9FAFB;
  --bg-input: #F3F4F6;

  /* 文字 */
  --text-primary: #1A1D28;
  --text-secondary: #6B7280;
  --text-muted: #9CA3AF;
  --text-placeholder: #C0C4CC;

  /* 边框 */
  --border: #EEF0F4;
  --border-light: #F3F4F6;

  /* 功能色 */
  --success: #10B981;
  --warning: #F59E0B;
  --danger: #EF4444;
  --orange: #FF6B35;

  /* 阴影 */
  --shadow-sm: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-full: 9999rpx;

  /* 字号 */
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 44rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;

  /* 基础 */
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: var(--font-md);
  color: var(--text-primary);
  background: var(--bg);
  line-height: 1.6;
  box-sizing: border-box;
}

/* ===== 深色主题 ===== */
.dark-mode {
  --primary: #5B8DEF;
  --primary-light: #1E2A4A;
  --primary-gradient: linear-gradient(135deg, #1A3070, #2B1A60);

  --bg: #0F0F0F;
  --bg-card: #1A1A1A;
  --bg-card-hover: #222222;
  --bg-input: #262626;

  --text-primary: #E8E8EC;
  --text-secondary: #9CA3AF;
  --text-muted: #6B7280;
  --text-placeholder: #555555;

  --border: #2A2A2A;
  --border-light: #222222;

  --success: #34D399;
  --warning: #FBBF24;
  --danger: #F87171;
  --orange: #FB923C;

  --shadow-sm: none;
  --shadow-md: none;
  --shadow-lg: none;

  color: var(--text-primary);
  background: var(--bg);
}

/* ========================================
   全局基础样式
   ======================================== */

/* 页面容器 */
.page {
  width: 100%;
  min-height: 100vh;
  background: var(--bg);
  box-sizing: border-box;
}

/* ===== 自定义导航栏 ===== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 248, 250, 0.92);
  backdrop-filter: blur(20rpx);
}
.dark-mode .nav-bar {
  background: rgba(15, 15, 15, 0.92);
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 var(--space-lg);
}

.nav-brand {
  display: flex;
  align-items: center;
  width: 160rpx;
}

.nav-logo {
  width: 56rpx;
  height: 56rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.nav-right {
  width: 160rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.nav-back {
  width: 90rpx;
  font-size: 50rpx;
  line-height: 1;
  font-weight: 300;
  color: var(--text-primary);
}

.nav-spacer {
  width: 90rpx;
}

/* ===== 卡片容器 ===== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* ===== 通用区域 ===== */
.section {
  margin: 0 var(--space-lg) var(--space-md);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: var(--font-sm);
  color: var(--text-muted);
}

/* ===== 列表项 ===== */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx var(--space-lg);
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-light);
}
.list-item:last-child {
  border-bottom: none;
}
.list-item:active {
  background: var(--bg-card-hover);
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: var(--border-light);
  margin: 0 var(--space-lg);
}

/* ===== 安全区底部 ===== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.empty-icon {
  font-size: 72rpx;
  opacity: 0.4;
}
.empty-text {
  font-size: var(--font-md);
  color: var(--text-muted);
  margin-top: var(--space-md);
}
.empty-sub {
  font-size: var(--font-xs);
  color: var(--text-placeholder);
  margin-top: var(--space-xs);
}

/* ========================================
   通用工具类
   ======================================== */

.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-blue { color: var(--primary); }
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-bold { font-weight: 600; }
.text-sm { font-size: var(--font-sm); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mt-8 { margin-top: var(--space-xs); }
.mt-12 { margin-top: var(--space-sm); }
.mt-16 { margin-top: var(--space-md); }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: var(--space-lg); }
.mb-8 { margin-bottom: var(--space-xs); }
.mb-12 { margin-bottom: var(--space-sm); }
.mb-16 { margin-bottom: var(--space-md); }
.mb-24 { margin-bottom: var(--space-lg); }
.ml-8 { margin-left: var(--space-xs); }
.mr-8 { margin-right: var(--space-xs); }
.p-16 { padding: var(--space-md); }
.p-24 { padding: var(--space-lg); }
.px-24 { padding-left: var(--space-lg); padding-right: var(--space-lg); }
.py-16 { padding-top: var(--space-md); padding-bottom: var(--space-md); }
.py-24 { padding-top: var(--space-lg); padding-bottom: var(--space-lg); }

.rounded-sm { border-radius: var(--radius-sm); }
.rounded-md { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-xl { border-radius: var(--radius-xl); }

.shadow-sm { box-shadow: var(--shadow-sm); }
.shadow-md { box-shadow: var(--shadow-md); }

.bg-white { background: var(--bg-card); }
.bg-primary { background: var(--primary); }
.bg-light { background: var(--primary-light); }

/* ===== 深色模式全局兜底 ===== */
/* 导航栏返回按钮/图标 — 确保深色模式可读 */
.dark-mode .nav-icon,
.dark-mode .nav-back,
.dark-mode .nav-left,
.dark-mode .nav-back-icon {
  color: #E8E8EC !important;
}

/* 导航栏背景 */
.dark-mode .nav-bar,
.dark-mode .nav-bar-inner {
  background: rgba(15, 15, 15, 0.95);
}

/* page + dark-mode 同元素兜底 */
.page.dark-mode {
  background: var(--bg);
}

/* 卡片/容器兜底 */
.dark-mode .card,
.dark-mode .form-card,
.dark-mode .info-card,
.dark-mode .record-card,
.dark-mode .review-card,
.dark-mode .post-card,
.dark-mode .detail-card,
.dark-mode .tip-card,
.dark-mode .section-card,
.dark-mode .comment-section,
.dark-mode .stat-card,
.dark-mode .parking-card,
.dark-mode .reminder-card,
.dark-mode .calc-card,
.dark-mode .result-card,
.dark-mode .preview-card,
.dark-mode .chart-section,
.dark-mode .price-overview,
.dark-mode .time-info,
.dark-mode .tab-bar,
.dark-mode .progress-section,
.dark-mode .category-section,
.dark-mode .empty-state {
  background: var(--bg-card);
}

/* 输入框/表单控件 */
.dark-mode .form-input,
.dark-mode .form-picker,
.dark-mode .form-textarea,
.dark-mode .text-input,
.dark-mode .date-field,
.dark-mode .unit-input,
.dark-mode .charge-input,
.dark-mode .price-input,
.dark-mode .loss-input {
  background: var(--bg-input);
  color: var(--text-primary);
  border-color: var(--border);
}

/* 浅色标签/徽标 */
.dark-mode .brand-tag,
.dark-mode .category-tag,
.dark-mode .filter-tag,
.dark-mode .station-brand,
.dark-mode .station-power,
.dark-mode .car-pill,
.dark-mode .badge-change {
  background: #2A2A2A;
  color: var(--text-secondary);
}

/* 选中态标签保持品牌色 */
.dark-mode .brand-tag.active,
.dark-mode .category-tag.active,
.dark-mode .filter-tag.active,
.dark-mode .cat-active,
.dark-mode .tag-active,
.dark-mode .tab-active,
.dark-mode .card-type.type-active,
.dark-mode .preset-active {
  background: var(--primary);
  color: #FFFFFF;
}

/* 浅色背景区块 */
.dark-mode .suggestion-card,
.dark-mode .urgent-banner,
.dark-mode .tip-box,
.dark-mode .presets-box,
.dark-mode .share-banner {
  background: #2A2A2A;
}

/* 按钮 */
.dark-mode .btn-cancel {
  background: #2A2A2A;
  color: var(--text-secondary);
}

.dark-mode .btn-save,
.dark-mode .empty-btn,
.dark-mode .share-btn,
.dark-mode .export-btn {
  background: var(--primary);
  color: #FFFFFF;
}

.dark-mode .delete-btn {
  background: #2A1A1A;
  color: var(--danger);
}

.dark-mode .edit-btn {
  background: #1E2A4A;
  color: var(--primary);
}

/* 分割线 */
.dark-mode .station-address,
.dark-mode .station-note,
.dark-mode .card-line,
.dark-mode .thin-line {
  border-color: var(--border);
}

/* 状态标签 */
.dark-mode .status-ok { background: #1A2A1A; }
.dark-mode .status-warn { background: #2A2A1A; }
.dark-mode .status-danger { background: #2A1A1A; }

/* 文字颜色 */
.dark-mode .station-name,
.dark-mode .info-text,
.dark-mode .form-title,
.dark-mode .form-label,
.dark-mode .tip-title,
.dark-mode .section-title,
.dark-mode .tab-item,
.dark-mode .time-label,
.dark-mode .category-header {
  color: var(--text-primary);
}

.dark-mode .address-text,
.dark-mode .tip-desc,
.dark-mode .tab-item,
.dark-mode .time-value,
.dark-mode .picker-arrow,
.dark-mode .legend-item {
  color: var(--text-secondary);
}